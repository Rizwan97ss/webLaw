---
const navLinks = [
  { label: "Home", href: "/", active: true },
  { label: "About Us", href: "/about" },
  { label: "Practice Areas", href: "/practice-areas", dropdown: true },
  { label: "Blog", href: "/blog", dropdown: true },
  { label: "Pages", href: "#", dropdown: true },
  { label: "Contact Us", href: "/contact", dropdown: true },
];
---

<header class="site-header">
  <div class="topbar">
    <div class="header-container topbar__inner">
      <div class="topbar__contact">
        <span>☎</span>
        <a href="tel:+0123456789">+01 23456789</a>

        <span>✉</span>
        <a href="mailto:contact@example.com">contact@example.com</a>
      </div>

      <div class="topbar__social">
        <a href="#">f</a>
        <a href="#">◎</a>
        <a href="#">in</a>
        <a href="#">◉</a>
      </div>
    </div>
  </div>

  <nav class="navbar">
    <div class="header-container navbar__inner">
      <a href="/" class="brand-logo">BRAND LOGO</a>

      <button class="nav-toggle" aria-label="Open menu">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="nav-menu">
        {navLinks.map((link) => (
          <a class={link.active ? "active" : ""} href={link.href}>
            {link.label}
            {link.dropdown && <span class="nav-arrow">⌄</span>}
          </a>
        ))}
      </div>

      <a href="/contact" class="header-cta">
        Free Consultation
        <span>→</span>
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const menu = document.querySelector(".nav-menu");

  toggle?.addEventListener("click", () => {
    toggle.classList.toggle("is-active");
    menu?.classList.toggle("is-open");
  });
</script>