---
const navLinks = [
  { label: "Home", href: "/", active: true },
  { label: "About Us", href: "/about" },
  {
    label: "Practice Areas",
    href: "#",
    children: [
      { label: "Practice Area", href: "/practice-area" },
      { label: "Practice Area Details", href: "/practice-area-details" },
    ],
  },
  {
    label: "Blog",
    href: "#",
    children: [
      { label: "Blog", href: "/blog" },
      { label: "Blog Details", href: "/trusted-legal-solutions-for-your-complex-cases" },
    ],
  },
  {
    label: "Pages",
    href: "#",
    children: [
      { label: "Case Study", href: "/case-study" },
      { label: "Attorney Profile", href: "/attorney-profile" },
      { label: "FAQ’s", href: "/faqs" },
    ],
  },
  {
    label: "Contact Us",
    href: "#",
    children: [
      { label: "Contact Style 1", href: "/contact-style-1" },
      { label: "Contact Style 2", href: "/contact-style-2" },
    ],
  },
];
---

<header class="site-header">
  <div class="topbar">
    <div class="header-container topbar__inner">
      <div class="topbar__contact">
        <a href="tel:+0123456789"><span><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone-icon lucide-phone"><path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2
           2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"/></svg></span> +01 23456789</a>
        <a href="mailto:contact@example.com"><span></span> contact@example.com</a>
      </div>

      <div class="topbar__social">
        <a href="#" aria-label="Facebook">f</a>
        <a href="#" aria-label="Instagram">◎</a>
        <a href="#" aria-label="LinkedIn">in</a>
        <a href="#" aria-label="WhatsApp">☏</a>
      </div>
    </div>
  </div>

  <nav class="navbar">
    <div class="header-container navbar__inner">
      <a href="/" class="brand-logo">
        <img src="/images/Normal-Logo.png" alt="Logo" />
      </a>

      <button class="nav-toggle" aria-label="Open menu">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <ul class="nav-menu">
        {navLinks.map((link) => (
          <li class={link.children ? "has-dropdown" : ""}>
            <a class={link.active ? "active" : ""} href={link.href}>
              {link.label}
              {link.children && <span class="nav-arrow">⌄</span>}
            </a>

            {link.children && (
              <ul class="sub-menu">
                {link.children.map((child) => (
                  <li>
                    <a href={child.href}>{child.label}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>

      <a href="/contact" class="header-cta">
        <span>Free Consultation</span>
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const menu = document.querySelector(".nav-menu");

  toggle?.addEventListener("click", () => {
    toggle.classList.toggle("is-active");
    menu?.classList.toggle("is-open");
  });

  document.querySelectorAll(".has-dropdown > a").forEach((item) => {
    item.addEventListener("click", (event) => {
      if (window.innerWidth <= 1024) {
        event.preventDefault();
        item.parentElement?.classList.toggle("is-open");
      }
    });
  });
</script>