---
const { item, index } = Astro.props;
const Icon = item.icon;
---

<article class="practice-card" data-reveal>
  <span class="practice-card__number">
    {String(index + 1).padStart(2, "0")}
  </span>

  <div class="practice-card__icon">
    <Icon size={32} strokeWidth={2.4} />
  </div>

  <div class="practice-card__content">
    <h3>{item.title}</h3>
    <p>{item.description}</p>

    <a class="btn btn--sm" href={`/practice-areas/${item.slug}`}>
      Read More
      <span>→</span>
    </a>
  </div>
</article>