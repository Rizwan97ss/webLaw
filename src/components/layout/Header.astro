---
const navLinks = [
  { label: "Home", href: "/", active: true },
  { label: "About Us", href: "/about" },
  {
    label: "Practice Areas",
    href: "#",
    children: [
      { label: "Practice Area", href: "/practice-area" },
      { label: "Practice Area Details", href: "/practice-area-details" },
    ],
  },
  {
    label: "Blog",
    href: "#",
    children: [
      { label: "Blog", href: "/blog" },
      { label: "Blog Details", href: "/trusted-legal-solutions-for-your-complex-cases" },
    ],
  },
  {
    label: "Pages",
    href: "#",
    children: [
      { label: "Case Study", href: "/case-study" },
      { label: "Attorney Profile", href: "/attorney-profile" },
      { label: "FAQ’s", href: "/faqs" },
    ],
  },
  {
    label: "Contact Us",
    href: "#",
    children: [
      { label: "Contact Style 1", href: "/contact-style-1" },
      { label: "Contact Style 2", href: "/contact-style-2" },
    ],
  },
];
---

<header class="site-header">
  <div class="topbar">
    <div class="header-container topbar__inner">
      <div class="topbar__contact">
        <a href="tel:+0123456789">
          <span>☎</span>
          +01 23456789
        </a>

        <a href="mailto:contact@example.com">
          <span>✉</span>
          contact@example.com
        </a>
      </div>

      <div class="topbar__social">
        <a href="#">f</a>
        <a href="#">◎</a>
        <a href="#">in</a>
        <a href="#">◉</a>
      </div>
    </div>
  </div>

  <nav class="navbar">
    <div class="header-container navbar__inner">
      <a href="/" class="brand-logo">CIVITAS</a>

      <button class="nav-toggle" aria-label="Open menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <ul class="nav-menu">
  {navLinks.map((link) => (
    <li class={link.children ? "has-dropdown" : ""}>
      <a class={link.active ? "active" : ""} href={link.href}>
        {link.label}
        {link.children && <span class="nav-arrow">⌄</span>}
      </a>

      {link.children && (
        <ul class="sub-menu">
          {link.children.map((child) => (
            <li>
              <a href={child.href}>{child.label}</a>
            </li>
          ))}
        </ul>
      )}
    </li>
  ))}
</ul>

      <a href="/contact" class="header-cta">
        Free Consultation
        <span>→</span>
      </a>
    </div>
  </nav>
</header>
<script>
  const toggle = document.querySelector(".nav-toggle");
  const menu = document.querySelector(".nav-menu");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("is-open");

    toggle.classList.toggle("is-active");
    toggle.setAttribute("aria-expanded", String(Boolean(isOpen)));
  });

  document.querySelectorAll(".has-dropdown > a").forEach((link) => {
    link.addEventListener("click", (event) => {
      if (window.innerWidth <= 1100) {
        event.preventDefault();
        link.parentElement?.classList.toggle("is-open");
      }
    });
  });
</script>