---
import { Menu, X, ChevronDown, Phone, Mail } from 'lucide-astro';
import { label } from 'motion/react-client';

const navLinks = [
  { label: "Home", href: "/" },
  { label: "About Us", href: "/about" },
  {
    label: "Practice Areas",
    href: "#",
    children: [
      { label: "Practice Area", href: "/practice-areas" },
      { label: "Practice Area Details", href: "/practice-areas/practice-details" },
    ],
  },
  {
    label: "Blog",
    href: "#",
    children: [
      { label: "Blog", href: "/blog" },
      { label: "Blog Details", href: "/blog/blog-details" },
    ],
  },
  {
    label: "Pages",
    href: "#",
    children: [
      { label: "Case Study", href: "/case-study" },
      { label: "Case Study Details", href: "/case-study/case_study_details" },
      { label: "Attorney Profile", href: "/attorney-profile" },
      {label: "Testimonial Style 1", href:"/testimonials/testimonial_1"},
      {label: "Testimonial Style 2", href:"/testimonials/testimonial_2"},
      {label: "Our Gallery", href:"/gallery/gallery"},
      { label: "FAQ's", href: "/faq/faq" },
      {label:"Disclaimer",href:"/disclaimer/disclaimer"},
      {label:"Privacy Policy",href:"/privacy/privacy"},
      {label:"404page",href:"/error/404page"},
    ],
  },
  {
    label: "Contact Us",
    href: "/#",
    children: [
      { label: "Contact Style 1", href: "/contact/contact_1" },
      { label: "Contact Style 2", href: "/contact/contact_2" },
    ],
  },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">

  <!-- ── Topbar (desktop only) ─────────────────────────── -->
  <div class="topbar">
    <div class="header-container topbar__inner">
      <div class="topbar__contact">
        <a href="tel:+0123456789">
          <Phone size={14} strokeWidth={2.5} />
          +01 23456789
        </a>
        <a href="mailto:contact@example.com">
          <Mail size={14} strokeWidth={2.5} />
          contact@example.com
        </a>
      </div>
      <div class="topbar__social">
        <a href="#" aria-label="Facebook">f</a>
        <a href="#" aria-label="Instagram">◎</a>
        <a href="#" aria-label="LinkedIn">in</a>
        <a href="#" aria-label="WhatsApp">☏</a>
      </div>
    </div>
  </div>

  <!-- ── Navbar ─────────────────────────────────────────── -->
  <nav class="navbar" id="navbar" role="navigation" aria-label="Main navigation">
    <div class="header-container navbar__inner">

      <!-- Logo -->
      <a href="/" class="brand-logo" aria-label="Civitas — go to homepage">CIVITAS</a>

      <!-- Desktop nav links -->
      <ul class="nav-menu" id="navMenu" role="menubar">
        {navLinks.map((link) => (
          <li class={link.children ? "has-dropdown" : ""} role="none">

            <a
              href={link.href}
              class={
                currentPath === link.href ||
                (link.href !== "/" && link.href !== "#" && currentPath.startsWith(link.href))
                  ? "active" : ""
              }
              role="menuitem"
            >
              {link.label}
              {link.children && (
                <span class="nav-arrow" aria-hidden="true">
                  <ChevronDown size={14} strokeWidth={2.5} />
                </span>
              )}
            </a>

            {link.children && (
              <ul class="sub-menu" role="menu" aria-label={link.label + " submenu"}>
                {link.children.map((child) => (
                  <li role="none">
                    <a href={child.href} role="menuitem">{child.label}</a>
                  </li>
                ))}
              </ul>
            )}

          </li>
        ))}
      </ul>

      <!-- CTA (desktop only) -->
      <a href="/contact" class="header-cta btn-fill-hover">
        Free Consultation <span aria-hidden="true">→</span>
      </a>

      <!-- Hamburger (mobile / tablet only) -->
      <button
        class="nav-toggle"
        id="navToggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="navMenu"
        type="button"
      >
        <span class="icon-open"  aria-hidden="true"><Menu size={22} strokeWidth={2.5} /></span>
        <span class="icon-close" aria-hidden="true"><X    size={22} strokeWidth={2.5} /></span>
      </button>

    </div>
  </nav>

</header>

<script>
  const toggle = document.getElementById('navToggle')   as HTMLButtonElement | null;
  const menu   = document.getElementById('navMenu')     as HTMLUListElement  | null;
  const navbar = document.getElementById('navbar')      as HTMLElement       | null;
  const header = document.getElementById('site-header') as HTMLElement       | null;
  const topbar = document.querySelector<HTMLElement>('.topbar');

  /* Measure real navbar height once and store as CSS var — no rounding mismatch */
  const navH = navbar?.getBoundingClientRect().height ?? 72;
  document.documentElement.style.setProperty('--navbar-h', navH + 'px');

  /* ── Open / close ──────────────────────────────────────── */
  function openMenu() {
    menu?.classList.add('is-open');
    toggle?.classList.add('is-active');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Close menu');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('is-open');
    toggle?.classList.remove('is-active');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Open menu');
    document.body.style.overflow = '';
    menu?.querySelectorAll('.has-dropdown.is-open').forEach(el => el.classList.remove('is-open'));
  }

  toggle?.addEventListener('click', () =>
    menu?.classList.contains('is-open') ? closeMenu() : openMenu()
  );

  /* Close on outside tap / click */
  document.addEventListener('click', (e) => {
    if (
      menu?.classList.contains('is-open') &&
      !menu.contains(e.target as Node) &&
      !toggle?.contains(e.target as Node)
    ) closeMenu();
  });

  /* Close when resized back to desktop */
  window.addEventListener('resize', () => {
    if (window.innerWidth > 1024) closeMenu();
  }, { passive: true });

  /* Escape key */
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  /* ── Accordion sub-menus (mobile only) ─────────────────── */
  menu?.querySelectorAll('.has-dropdown > a').forEach((link) => {
    link.addEventListener('click', (e) => {
      if (window.innerWidth > 1024) return;          // desktop uses CSS :hover
      e.preventDefault();

      const parent = (link as HTMLElement).parentElement;
      const willOpen = !parent?.classList.contains('is-open');

      // collapse all open siblings first
      menu?.querySelectorAll('.has-dropdown.is-open').forEach(sib => {
        if (sib !== parent) sib.classList.remove('is-open');
      });

      parent?.classList.toggle('is-open', willOpen);
    });
  });

  /* ── Sticky navbar ─────────────────────────────────────── */
  const stickyAt = topbar?.offsetHeight ?? 40;

  window.addEventListener('scroll', () => {
    const sticky = window.scrollY >= stickyAt;
    navbar?.classList.toggle('is-sticky', sticky);
    header?.classList.toggle('nav-fixed', sticky);
  }, { passive: true });
</script>
