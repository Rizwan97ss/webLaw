---
import {
  Scale,
  UserRound,
  Smile,
  Medal,
} from "lucide-react";

const stats = [
  {
    icon: Scale,
    value: "1K+",
    label: "Cases Completed",
  },
  {
    icon: UserRound,
    value: "10+",
    label: "Expert Attorneys",
  },
  {
    icon: Smile,
    value: "2K+",
    label: "Happy Clients",
  },
  {
    icon: Medal,
    value: "20+",
    label: "Award Winning",
  },
];
---

<section class="stats">
  <div class="container">
    <div class="stats-grid">
      {
        stats.map((item, i) => {
          const Icon = item.icon;

          return (
            <article class="stat-card" data-reveal style={`--reveal-delay: ${i * 110}ms`}>
              <div class="stat-icon">
                <Icon size={38} strokeWidth={2.3} />
              </div>

              <div class="stat-content">
                <span class="counter" data-count={item.value}>0</span>
                <span class="stat-label">{item.label}</span>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
<script>
  import { initCounters } from '../../scripts/counter';
  initCounters();
</script>