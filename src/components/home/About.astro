---
const isHomePage = Astro.url.pathname === "/";
---
<section class="about-section">
  <div class="container">
    <div class="about-card">
      <div class="about-image-wrap" data-reveal="left">
        <div class="shine-image about-image-shine">
          <img
            src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=900&q=80"
            alt="Court room"
            class="about-image"
          />
        </div>

        <div class="experience-badge">
          <strong>10+</strong>
          <span>Years Of</span>
          <span>Experience</span>
        </div>
      </div>

      <div class="about-content" data-reveal="right">
        <p class="about-kicker">⚖ About Civitas</p>

        <h2>
          Committed to Excellence in
          <br />
          Advocacy
        </h2>

        <p class="about-text">
          Founded on the principles of integrity and relentless pursuit of justice,
          our firm provides sophisticated legal counsel tailored to the unique
          needs of every client. We don’t just practice law; we solve problems.
        </p>

        <ul class="about-list">
          <li>Corporate &amp; Business Law</li>
          <li>Estate Planning &amp; Probate</li>
          <li>Personal Injury Litigation</li>
          <li>Real Estate Law</li>
        </ul>

         <a
  href={isHomePage ? "/about" : "/contact/contact_1"}
  class="practice-view-btn btn-fill-hover"
>
  {isHomePage ? "Read More" : "Contact Us"}
  <span>→</span>
</a>
      </div>
    </div>
  </div>
</section>