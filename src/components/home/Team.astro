---
import { ChevronLeft, ChevronRight, Scale } from "lucide-react";
import img1278242 from "../../assets/1278242.jpg";
import img642888 from "../../assets/642888.jpg";
import img1701078 from "../../assets/1701078.jpg";
import img1046502 from "../../assets/1046502.jpg";
import img632090 from "../../assets/632090.jpg";

const attorneys = [
  {
    name: "Jonathan R.",
    role: "Business Attorney",
    image: img1278242.src,
    social: { fb: "#", x: "#", ig: "#", wa: "#" },
  },
  {
    name: "Sarah Jenkins",
    role: "Family Attorney",
    image: img642888.src,
    social: { fb: "#", x: "#", ig: "#", wa: "#" },
  },
  {
    name: "Marcus Thorne",
    role: "Defense Attorney",
    image: img1701078.src,
    social: { fb: "#", x: "#", ig: "#", wa: "#" },
  },
  {
    name: "Elena M.",
    role: "Personal Attorney",
    image: img1046502.src,
    social: { fb: "#", x: "#", ig: "#", wa: "#" },
  },
  {
    name: "David K.",
    role: "Corporate Attorney",
    image: img632090.src,
    social: { fb: "#", x: "#", ig: "#", wa: "#" },
  },
];
---

<section class="team-section">
  <div class="container">
    <div class="team-head">
      <p class="section-kicker"><Scale size={16} className="kicker-icon" /> Our Attorneys</p>
      <h2>Trusted Legal Experts</h2>
    </div>

    <div class="team-carousel-wrap">
      <div class="team-track-outer">
        <div class="team-track">
          {
            attorneys.map((attorney) => (
              <article class="team-card">
                <div class="team-card__inner">
                  <img
                    src={attorney.image}
                    alt={attorney.name}
                    loading="lazy"
                    decoding="async"
                  />

                  <div class="team-overlay" />

                  <div class="team-social">
                    <a href={attorney.social.fb} aria-label="Facebook">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                    </a>
                    <a href={attorney.social.x} aria-label="X">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                    <a href={attorney.social.ig} aria-label="Instagram">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>
                    </a>
                    <a href={attorney.social.wa} aria-label="WhatsApp">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.533 5.857L.057 23.571a.562.562 0 0 0 .693.693l5.714-1.476A11.936 11.936 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.797 9.797 0 0 1-5.001-1.368l-.358-.214-3.715.959.98-3.622-.234-.374A9.797 9.797 0 0 1 2.182 12C2.182 6.568 6.568 2.182 12 2.182S21.818 6.568 21.818 12 17.432 21.818 12 21.818z"/></svg>
                    </a>
                  </div>

                  <div class="team-name-tag">
                    <h4>{attorney.name}</h4>
                    <p>{attorney.role}</p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <div class="team-arrows">
        <button class="team-arrow team-prev" type="button" aria-label="Previous">
          <ChevronLeft size={22} />
        </button>
        <button class="team-arrow team-next" type="button" aria-label="Next">
          <ChevronRight size={22} />
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  import { createInfiniteCarousel } from '../../scripts/infiniteCarousel';
  createInfiniteCarousel();
</script>
