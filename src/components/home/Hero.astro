---
import Button from "../common/Button.astro";
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <div class="hero__rating">
        <span class="hero__stars">★★★★★</span>
        <strong>Trusted by 1,000+ clients</strong>
      </div>

      <h1>Justice Driven by Experience</h1>

      <p>
        Navigating complex legal challenges with strategic precision and unwavering advocacy.
        <br />
        We protect your rights, your family, and your future.
      </p>

      <div class="hero__actions">
        <a href="/contact" class="hero-btn">
          Free Consultation
          <span>→</span>
        </a>

        <a href="#" class="video-btn">
          <span class="video-btn__icon">▶</span>
          <span>Watch Video</span>
        </a>
      </div>
    </div>

    <div class="hero__image">
      <img src="/images/hero-lawyer.jpg" alt="Lawyer working at desk" />
    </div>
  </div>
</section>