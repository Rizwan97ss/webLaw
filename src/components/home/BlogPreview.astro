---
import { ChevronRight, ChevronLeft, Scale, User, Tag, MoveRight } from 'lucide-react';
import img859219 from "../../assets/859219.jpg";
import img719590 from "../../assets/719590.jpg";
import img801066 from "../../assets/801066.jpg";

const posts = [
  {
    slug: "protecting-your-rights-with-professional-legal-services",
    title: "Protecting Your Rights with Professional Legal Services",
    author: "Civitas Law",
    category: "Real Estate Law",
    date: "Mar 28, 2026",
    image: img859219.src,
  },
  {
    slug: "expert-lawyer-guidance-for-business-and-personal-matters",
    title: "Expert Lawyer Guidance for Business and Personal Matters",
    author: "Civitas Law",
    category: "Criminal Law",
    date: "Mar 10, 2026",
    image: img719590.src,
  },
  {
    slug: "trusted-legal-solutions-for-your-complex-cases",
    title: "Trusted Legal Solutions for Your Complex Cases",
    author: "Civitas Law",
    category: "Family Law",
    date: "Mar 2, 2026",
    image: img801066.src,
  },
  {
    slug: "smart-estate-planning-for-long-term-family-security",
    title: "Smart Estate Planning for Long-Term Family Security",
    author: "Civitas Law",
    category: "Estate Planning",
    date: "Feb 18, 2026",
    image: img859219.src,
  },
  {
    slug: "how-strong-contracts-protect-your-business",
    title: "How Strong Contracts Protect Your Business",
    author: "Civitas Law",
    category: "Business Law",
    date: "Feb 8, 2026",
    image: img719590.src,
  },
];
---

<section class="home-blog-section">
  <div class="container">
    <div class="blog-head">
      <div>
        <p class="blog-kicker"><Scale size={16} className="kicker-icon" /> News & Blog</p>
        <h2>Latest News & Update</h2>
      </div>
 <a href="/blog" class="practice-view-btn btn-fill-hover">
  View More <MoveRight size={16} />
</a>
      
    </div>

    <div class="blog-slider">
      <div class="blog-track">
        {posts.map((post) => (
          <article class="blog-slide">
            <div class="blog-card">
              <div class="blog-image shine-image">
                <img src={post.image} alt={post.title} />
                <span class="blog-badge">{post.date}</span>
              </div>

              <div class="blog-body">
                <div class="blog-meta">
                  <span><User size={13} /> By {post.author}</span>
                  <span><Tag size={13} /> {post.category}</span>
                </div>

                <h3>{post.title}</h3>

                <a href={`/blog/${post.slug}`} class="practice-view-btn btn-fill-hover">
                  Read More <MoveRight size={16} />
                </a>
              </div>

            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="blog-arrows">
      <button class="blog-arrow blog-prev" type="button"><ChevronLeft /></button>
      <button class="blog-arrow blog-next" type="button"><ChevronRight /></button>
    </div>
  </div>
</section>

<script>
  import { createSlider } from '../../scripts/slider';
  import { siteConfig } from '../../config/site.config';
  createSlider({
    trackSelector: '.blog-track',
    slideSelector: '.blog-slide',
    prevSelector:  '.blog-prev',
    nextSelector:  '.blog-next',
    visibleCards:  siteConfig.blog.visibleCards,
    breakpoints:   siteConfig.blog.breakpoints,
  });
</script>