---

<section class="blog-section">
  <div class="container">
    <div class="blog-head">
      <div>
        <p class="blog-kicker">⚖ News & Blog</p>
        <h2>Latest News & Update</h2>
      </div>

      <a href="/blog" class="blog-view">
        View More <span>→</span>
      </a>
    </div>

    <div class="blog-slider">
      <div class="blog-track">
        {posts.map((post) => (
          <article class="blog-slide">
            <div class="blog-card">
              <div class="blog-image">
                <img src={post.image} alt={post.title} />
                <span>{post.date}</span>
              </div>

              <div class="blog-meta">
                <span>♟ By {post.author}</span>
                <span>🏷 {post.category}</span>
              </div>

              <h3>{post.title}</h3>

              <a href="/blog" class="blog-btn">
                Read More <span>→</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="blog-arrows">
      <button class="blog-arrow blog-prev" type="button">‹</button>
      <button class="blog-arrow blog-next" type="button">›</button>
    </div>
  </div>
</section>

<script>
  const blogTrack = document.querySelector(".blog-track");
  const blogSlides = document.querySelectorAll(".blog-slide");
  const blogPrev = document.querySelector(".blog-prev");
  const blogNext = document.querySelector(".blog-next");

  let blogIndex = 0;

  function visibleBlogCards() {
    if (window.innerWidth <= 640) return 1;
    if (window.innerWidth <= 1024) return 2;
    return 3;
  }

  function updateBlogSlider() {
    if (!blogTrack || !blogSlides.length) return;

    const visible = visibleBlogCards();
    const maxIndex = Math.max(blogSlides.length - visible, 0);

    if (blogIndex > maxIndex) blogIndex = maxIndex;

    const slideWidth = blogSlides[0].getBoundingClientRect().width;
    blogTrack.style.transform = `translateX(-${blogIndex * slideWidth}px)`;
  }

  blogNext?.addEventListener("click", () => {
    const maxIndex = Math.max(blogSlides.length - visibleBlogCards(), 0);
    blogIndex = blogIndex >= maxIndex ? 0 : blogIndex + 1;
    updateBlogSlider();
  });

  blogPrev?.addEventListener("click", () => {
    const maxIndex = Math.max(blogSlides.length - visibleBlogCards(), 0);
    blogIndex = blogIndex <= 0 ? maxIndex : blogIndex - 1;
    updateBlogSlider();
  });

  window.addEventListener("resize", updateBlogSlider);
  updateBlogSlider();
</script>