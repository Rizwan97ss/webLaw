    author: "Civitas Law",
    category: "Real Estate Law",
    date: "Mar 28, 2026",
    image: "https://images.unsplash.com/photo-1589994965851-a8f479c573a9?auto=format&fit=crop&w=900&q=80",
  },
  {
    title: "Expert Lawyer Guidance for Business and Personal Matters",
    author: "Civitas Law",
    category: "Criminal Law",
    date: "Mar 10, 2026",
    image: "https://images.unsplash.com/photo-1589829545856-d10d557cf95f?auto=format&fit=crop&w=900&q=80",
  },
  {
    title: "Trusted Legal Solutions for Your Complex Cases",
    author: "Civitas Law",
    category: "Family Law",
    date: "Mar 2, 2026",
    image: "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=900&q=80",
  },
  {
    title: "Smart Estate Planning for Long-Term Family Security",
    author: "Civitas Law",
