---
import { ChevronRight, ChevronLeft, Scale, MoveRight } from "lucide-react";

const isHomePage =
  Astro.url.pathname === "/" ||
  Astro.url.pathname === "/case-study" ||
  Astro.url.pathname === "/attorney-profile" ||
  Astro.url.pathname === "/practice-areas";
const testimonials = [
  {
    logo: "BRAND LOGO",
    quote:
      "During the most difficult time of my life, their team provided both empathy and a brilliant legal defense. I couldn't have asked.",
    name: "Sarah L",
    role: "Family Law Client",
    image:
      "https://civitas.divigurus.com/wp-content/uploads/2026/04/laptop-notebook-work-hand-suit-people-1278242-pxhere.com_.jpg",
  },
  {
    logo: "BRAND LOGO",
    quote:
      "After a serious accident, I felt overwhelmed. They took over the fight and secured a settlement that changed my family's .",
    name: "David K",
    role: "Corporate Law Client",
    image:
      "https://civitas.divigurus.com/wp-content/uploads/2026/04/person-people-girl-woman-hair-white-642888-pxhere.com_11zon-scaled-1.jpg",
  },
  {
    logo: "BRAND LOGO",
    quote:
      "Their strategic approach to our complex merger saved us months of negotiation. They are more than just lawyers; they are .",
    name: "Michael R",
    role: "Personal Injury Client",
    image:
      "https://civitas.divigurus.com/wp-content/uploads/2026/04/man-person-people-hair-white-boy-1046502-pxhere.com_.jpg",
  },
  {
    logo: "BRAND LOGO",
    quote:
      "After a serious accident, I felt overwhelmed. They took over the fight and secured a settlement that changed my family's .",
    name: "David K",
    role: "Corporate Law Client",
    image:
      "https://civitas.divigurus.com/wp-content/uploads/2026/04/person-people-girl-woman-hair-white-642888-pxhere.com_11zon-scaled-1.jpg",
  },
  {
    logo: "BRAND LOGO",
    quote:
      "Their strategic approach to our complex merger saved us months of negotiation. They are more than just lawyers; they are .",
    name: "Michael R",
    role: "Personal Injury Client",
    image:
      "https://civitas.divigurus.com/wp-content/uploads/2026/04/man-person-people-hair-white-boy-1046502-pxhere.com_.jpg",
  },
  {
    logo: "BRAND LOGO",
    quote:
      "After a serious accident, I felt overwhelmed. They took over the fight and secured a settlement that changed my family's .",
    name: "David K",
    role: "Corporate Law Client",
    image:
      "https://civitas.divigurus.com/wp-content/uploads/2026/04/person-people-girl-woman-hair-white-642888-pxhere.com_11zon-scaled-1.jpg",
  },
  {
    logo: "BRAND LOGO",
    quote:
      "Their strategic approach to our complex merger saved us months of negotiation. They are more than just lawyers; they are .",
    name: "Michael R",
    role: "Personal Injury Client",
    image:
      "https://civitas.divigurus.com/wp-content/uploads/2026/04/man-person-people-hair-white-boy-1046502-pxhere.com_.jpg",
  },
];
---

<section class="testimonial-section">
  <div class="container">
    <div class="testimonial-head">
      <div>
        <p class="testimonial-kicker">
          <Scale size={16} className="kicker-icon" /> Testimonials
        </p>
        <h2>What Our Client's Say</h2>
      </div>

      {
        isHomePage && (
          <a
            href="/testimonials/testimonial_1"
            class="practice-view-btn btn-fill-hover"
          >
            View More <MoveRight size={16} />
          </a>
        )
      }
    </div>

    {
      isHomePage ? (
        <>
          <div class="testimonial-slider" data-reveal>
            <div class="testimonial-track">
              {testimonials.map((item) => (
                <article class="testimonial-card">
                  <div class="testimonial-card__inner">
                    <div class="testimonial-box">
                      <div class="testimonial-top">
                        <strong>{item.logo}</strong>
                        <span>★★★★★</span>
                      </div>

                      <div class="testimonial-line" />

                      <p>{item.quote}</p>
                    </div>

                    <div class="testimonial-author">
                      <img src={item.image} alt={item.name} />

                      <div>
                        <h3>{item.name}</h3>
                        <span>{item.role}</span>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>

          {isHomePage ? (
            <div class="testimonial-arrows">
              <button class="testimonial-arrow testimonial-prev" type="button">
                <ChevronLeft />
              </button>

              <button class="testimonial-arrow testimonial-next" type="button">
                <ChevronRight />
              </button>
            </div>
          ) : null}
        </>
      ) : (
        <div class="testimonial-grid-page">
          {testimonials.slice(0, 6).map((item) => (
            <article class="testimonial-card-page">
              <div class="testimonial-box">
                <div class="testimonial-top">
                  <strong>{item.logo}</strong>
                  <span>★★★★★</span>
                </div>

                <div class="testimonial-line" />

                <p>{item.quote}</p>
              </div>

              <div class="testimonial-author">
                <img src={item.image} alt={item.name} />

                <div>
                  <h3>{item.name}</h3>
                  <span>{item.role}</span>
                </div>
              </div>
            </article>
          ))}
        </div>
      )
    }
  </div>
</section>
<script>
  import { createSlider } from "../../scripts/slider";
  import { siteConfig } from "../../config/site.config";
  createSlider({
    trackSelector: ".testimonial-track",
    slideSelector: ".testimonial-card",
    prevSelector: ".testimonial-prev",
    nextSelector: ".testimonial-next",
    visibleCards: siteConfig.testimonials.visibleCards,
    breakpoints: siteConfig.testimonials.breakpoints,
  });
</script>
