---
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
---

<MainLayout title="404 - Page Not Found | Civitas Law">
  <Header />

  <section class="error-section">
    <div class="error-inner">

      <div class="error-number">404</div>

      <h2>Oops! Page Not Found</h2>

      <p>The page you are looking for does not exist.</p>

      <a href="/" class="error-btn btn-fill-hover">Back To Home</a>

    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  /* ── Section ─────────────────────────────────────── */
  .error-section {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 20px;
    background: #fff;
  }

  /* ── Centered content ─────────────────────────────── */
  .error-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    max-width: 600px;
  }

  /* ── Big 404 number ───────────────────────────────── */
  .error-number {
    font-size: clamp(100px, 18vw, 180px);
    font-weight: 800;
    line-height: 1;
    color: var(--gcid-primary-color, #ffc342);
    letter-spacing: -4px;
    user-select: none;
  }

  /* ── Heading ─────────────────────────────────────── */
  .error-inner h2 {
    margin: 0;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--gcid-heading-color, #101932);
    line-height: 1.2;
  }

  /* ── Description ──────────────────────────────────── */
  .error-inner p {
    margin: 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--gcid-body-color, #505658);
  }

  /* ── Button ───────────────────────────────────────── */
  .error-btn {
    display: inline-block;
    margin-top: 10px;
    padding: 14px 34px;
    background: var(--gcid-primary-color, #ffc342);
    color: var(--gcid-heading-color, #101932);
    border-radius: 100px;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.3s;
  }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 480px) {
    .error-section {
      padding: 60px 20px;
    }
  }
</style>
