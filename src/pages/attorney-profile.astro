---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import PageHero from "../components/common/PageHero.astro";
import { Award, Mail, Phone, Printer, Trophy, Star, Medal, BadgeCheck } from "lucide-astro";
import Testimonials from "../components/home/Testimonials.astro";

const skills = [
  { label: "Complex Litigation",     pct: 80 },
  { label: "Corporate Counseling",   pct: 70 },
  { label: "Strategic Negotiations", pct: 90 },
  { label: "Appellate Law",          pct: 75 },
];

const achievements = [
  { icon: Trophy,    title: "Top 100 Attorneys",    desc: "Legal Excellence Magazine, 2024"       },
  { icon: Star,      title: "AV Preeminent Rating", desc: "Highest Level of Professional Excellence" },
  { icon: Medal,     title: "Rising Star Award",    desc: "Regional Bar Association"              },
  { icon: BadgeCheck,title: "Lead Counsel Verified",desc: "Since 2022"                           },
];

const services = [
  "Corporate & Business Law",
  "Family Law & Mediation",
  "Personal Injury Litigation",
  "Estate Planning & Probate",
  "Criminal Defense",
  "Real Estate Law",
];

const stats = [
  { icon: Award,   label: "Experience", value: "More Than 5+ Years"  },
  { icon: Mail,    label: "Email",      value: "contact@example.com"  },
  { icon: Phone,   label: "Phone",      value: "+01 23456789"         },
  { icon: Printer, label: "Fax",        value: "+01 23456789"         },
];

const socials = [
  { label: "Facebook",  char: "f",  href: "#" },
  { label: "Instagram", char: "◎", href: "#" },
  { label: "LinkedIn",  char: "in", href: "#" },
  { label: "WhatsApp",  char: "☏",  href: "#" },
];
---

<MainLayout title="Attorney Profile - Civitas Law">
  <Header />
  <PageHero title="Attorney Profile" />

  <section class="atty-section">
    <div class="container atty-grid">

      <!-- ── Photo ─────────────────────────────────────── -->
      <div class="atty-photo shine-image">
        <img
          src="https://civitas.divigurus.com/wp-content/uploads/2026/03/documents-contract-eyebrow-collar-formal-wear-neck-1707616-pxhere.com_11zon-scaled.jpg"
          alt="Elena M. — Personal Attorney"
          fetchpriority="high"
          decoding="async"
        />
      </div>

      <!-- ── Info ──────────────────────────────────────── -->
      <div class="atty-info">
        <h2 class="atty-name">Elena M.</h2>
        <p class="atty-role">Personal Attorney</p>

        <!-- Stats 2×2 grid -->
        <div class="atty-stats">
          {stats.map(({ icon: Icon, label, value }) => (
            <div class="atty-stat">
              <span class="atty-stat__icon">
                <Icon size={22} />
              </span>
              <div>
                <h4>{label}</h4>
                <p>{value}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Social links -->
        <div class="atty-social">
          {socials.map((s) => (
            <a href={s.href} class="atty-social__link" aria-label={`Follow on ${s.label}`} target="_self" rel="noopener">
              {s.char}
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ── About ─────────────────────────────────────────── -->
  <section class="atty-about">
    <div class="container">
      <h2>About Elena M.</h2>
      <p>With over 5+ years of experience in the legal industry, Elena M. has built a reputation for meticulous case preparation and a relentless commitment to client success. Specializing in Corporate & Business Law, she has successfully navigated complex legal landscapes for both individuals and corporate entities.</p>
      <p>Elena believes that effective representation starts with a deep understanding of the client's unique goals. By combining aggressive advocacy with strategic negotiation, she ensures that every client receives a tailored legal strategy designed to achieve the best possible outcome.</p>
    </div>
  </section>

  <!-- ── Skills + Achievements ─────────────────────────── -->
  <section class="atty-skills-section">
    <div class="container atty-skills-grid">

      <!-- Skills -->
      <div class="atty-skills-col">
        <h2>Professional Skills</h2>
        <p class="atty-skills-lead">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nulla nec rutrum velit. Morbi mattis tellus ante.</p>

        <div class="atty-bars">
          {skills.map((s) => (
            <div class="atty-bar-item">
              <div class="atty-bar-header">
                <span>{s.label}</span>
                <span class="atty-bar-pct">{s.pct}%</span>
              </div>
              <div class="atty-bar-track">
                <div class="atty-bar-fill" data-pct={s.pct}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Achievements -->
      <div class="atty-achv-col">
        <h2>Achievements</h2>
        <p class="atty-skills-lead">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nulla nec rutrum velit. Morbi mattis tellus ante.</p>

        <div class="atty-achv-grid">
          {achievements.map(({ icon: Icon, title, desc }) => (
            <div class="atty-achv-card">
              <span class="atty-achv-card__icon">
                <Icon size={28} />
              </span>
              <h4>{title}</h4>
              <p>{desc}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ── Contact form ───────────────────────────────────── -->
  <section class="atty-contact-section">
    <div class="container atty-contact-inner">
      <h2>Let's Win Together</h2>

      <form class="atty-contact-form">
        <div class="atty-form-row">
          <input type="text"  placeholder="Name"         required />
          <input type="tel"   placeholder="Phone Number" pattern="[0-9\s\-]*" required />
        </div>
        <input type="email"   placeholder="Email Address" required />
        <select required>
          <option value="">Select Service</option>
          {services.map((s) => <option value={s}>{s}</option>)}
        </select>
        <textarea placeholder="Your Message" required></textarea>
        <div class="atty-form-action">
          <button type="submit" class="btn-fill-hover">
            Book Appointment <span>→</span>
          </button>
        </div>
      </form>
    </div>
  </section>

<Testimonials/>
  <Footer />
</MainLayout>

<style>
  /* ── Section ───────────────────────────────────────── */
  .atty-section {
    padding: 80px 0;
  }

  /* ── Two-column grid (photo | info) ────────────────── */
  .atty-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 60px;
    align-items: start;
  }

  /* ── Photo ─────────────────────────────────────────── */
  .atty-photo img {
    width: 100%;
    height: 480px;
    object-fit: cover;
    object-position: top;
    display: block;
    border-radius: 10px;
  }

  /* ── Info column ────────────────────────────────────── */
  .atty-info {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .atty-name {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 700;
    color: var(--gcid-heading-color, #242424);
    line-height: 1.1;
  }

  .atty-role {
    margin: 0;
    font-size: 17px;
    font-weight: 500;
    color: var(--gcid-primary-color, #ffc64a);
    font-family: var(--font-cabin, "Cabin", sans-serif);
  }

  /* ── Stats 2×2 grid ─────────────────────────────────── */
  .atty-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .atty-stat {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    border-radius: 10px;
    background: color-mix(in srgb, var(--gcid-primary-color, #ffc64a) 12%, white);
  }

  .atty-stat__icon {
    width: 50px;
    height: 50px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--gcid-primary-color, #ffc64a);
    color: #242424;
  }

  .atty-stat h4 {
    margin: 0 0 3px;
    font-size: 13px;
    font-weight: 600;
    color: var(--gcid-body-color, #6b6b6b);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .atty-stat p {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    color: var(--gcid-heading-color, #242424);
  }

  /* ── Social links ───────────────────────────────────── */
  .atty-social {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .atty-social__link {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: color-mix(in srgb, var(--gcid-primary-color, #ffc64a) 15%, white);
    color: var(--gcid-heading-color, #242424);
    text-decoration: none;
    font-size: 15px;
    font-weight: 700;
    transition: background 0.2s, color 0.2s;
  }

  .atty-social__link:hover {
    background: var(--gcid-primary-color, #ffc64a);
    color: #242424;
  }

  /* ── About section ─────────────────────────────────── */
  .atty-about {
    padding: 70px 0;
    background: color-mix(in srgb, var(--gcid-primary-color, #ffc64a) 6%, white);
  }

  .atty-about h2 {
    margin: 0 0 20px;
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 700;
    color: var(--gcid-heading-color, #242424);
  }

  .atty-about p {
    margin: 0 0 16px;
    font-size: 16px;
    line-height: 1.8;
    color: var(--gcid-body-color, #6b6b6b);
    max-width: 820px;
  }

  .atty-about p:last-child { margin-bottom: 0; }

  /* ── Skills + Achievements section ─────────────────── */
  .atty-skills-section {
    padding: 80px 0;
  }

  .atty-skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .atty-skills-col h2,
  .atty-achv-col h2 {
    margin: 0 0 12px;
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    font-weight: 700;
    color: var(--gcid-heading-color, #242424);
  }

  .atty-skills-lead {
    margin: 0 0 28px;
    font-size: 15px;
    line-height: 1.7;
    color: var(--gcid-body-color, #6b6b6b);
  }

  /* Progress bars */
  .atty-bars {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .atty-bar-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    font-size: 15px;
    font-weight: 600;
    color: var(--gcid-heading-color, #242424);
  }

  .atty-bar-pct {
    color: var(--gcid-primary-color, #ffc64a);
  }

  .atty-bar-track {
    height: 10px;
    border-radius: 100px;
    background: #eee;
    overflow: hidden;
  }

  .atty-bar-fill {
    height: 100%;
    border-radius: 100px;
    background: var(--gcid-primary-color, #ffc64a);
    width: 0%;
    transition: width 1.2s ease;
  }

  /* Achievements 2x2 */
  .atty-achv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .atty-achv-card {
    padding: 20px 18px;
    border-radius: 10px;
    background: color-mix(in srgb, var(--gcid-primary-color, #ffc64a) 10%, white);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .atty-achv-card__icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--gcid-primary-color, #ffc64a);
    color: #242424;
    flex-shrink: 0;
  }

  .atty-achv-card h4 {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    color: var(--gcid-heading-color, #242424);
    line-height: 1.3;
  }

  .atty-achv-card p {
    margin: 0;
    font-size: 13px;
    color: var(--gcid-body-color, #6b6b6b);
    line-height: 1.5;
  }

  /* ── Contact form section ───────────────────────────── */
  .atty-contact-section {
    padding: 80px 0;
    background: color-mix(in srgb, var(--gcid-primary-color, #ffc64a) 6%, white);
  }

  .atty-contact-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .atty-contact-inner h2 {
    margin: 0 0 32px;
    font-size: clamp(1.6rem, 2.5vw, 2.4rem);
    font-weight: 700;
    color: var(--gcid-heading-color, #242424);
  }

  .atty-contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: left;
    background: #fff;
    border-radius: 14px;
    padding: 36px 32px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  }

  .atty-contact-form input,
  .atty-contact-form select,
  .atty-contact-form textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1.5px solid #e8e8e8;
    border-radius: 8px;
    font-size: 15px;
    font-family: var(--font-cabin, "Cabin", sans-serif);
    color: #242424;
    background: #fff;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .atty-contact-form input:focus,
  .atty-contact-form select:focus,
  .atty-contact-form textarea:focus {
    border-color: var(--gcid-primary-color, #ffc64a);
  }

  .atty-contact-form textarea {
    height: 140px;
    resize: vertical;
  }

  .atty-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .atty-form-action {
    display: flex;
    justify-content: center;
    padding-top: 4px;
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 980px) {
    .atty-section {
      padding: 50px 0;
    }

    .atty-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .atty-photo {
      width: 70%;
    }

    .atty-photo img {
      height: 500px;
    }
  }

  @media (max-width: 640px) {
    .atty-stats {
      grid-template-columns: 1fr;
    }

    .atty-stat__icon {
      width: 40px;
      height: 40px;
    }

    .atty-photo {
      width: 100%;
    }

    .atty-photo img {
      height: 350px;
    }

    .atty-skills-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .atty-achv-grid {
      grid-template-columns: 1fr;
    }

    .atty-skills-section,
    .atty-contact-section,
    .atty-about {
      padding: 40px 0;
    }

    .atty-form-row {
      grid-template-columns: 1fr;
    }

    .atty-contact-form {
      padding: 24px 18px;
    }
  }
</style>

<script>
  /* Animate progress bars when they scroll into view */
  const bars = document.querySelectorAll<HTMLElement>(".atty-bar-fill");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const bar = entry.target as HTMLElement;
          bar.style.width = (bar.dataset.pct ?? "0") + "%";
          observer.unobserve(bar);
        }
      });
    },
    { threshold: 0.3 }
  );

  bars.forEach((bar) => observer.observe(bar));
</script>
