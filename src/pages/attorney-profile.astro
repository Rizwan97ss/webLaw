---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import PageHero from "../components/common/PageHero.astro";
import {
  Award,
  Mail,
  Phone,
  Printer,
  Trophy,
  Star,
  Medal,
  BadgeCheck,
  MoveRight,
} from "lucide-astro";
import Testimonials from "../components/home/Testimonials.astro";

const skills = [
  { label: "Complex Litigation", pct: 80 },
  { label: "Corporate Counseling", pct: 70 },
  { label: "Strategic Negotiations", pct: 90 },
  { label: "Appellate Law", pct: 75 },
];

const achievements = [
  {
    icon: Trophy,
    title: "Top 100 Attorneys",
    desc: "Legal Excellence Magazine, 2024",
  },
  {
    icon: Star,
    title: "AV Preeminent Rating",
    desc: "Highest Level of Professional Excellence",
  },
  { icon: Medal, title: "Rising Star Award", desc: "Regional Bar Association" },
  { icon: BadgeCheck, title: "Lead Counsel Verified", desc: "Since 2022" },
];

const services = [
  "Corporate & Business Law",
  "Family Law & Mediation",
  "Personal Injury Litigation",
  "Estate Planning & Probate",
  "Criminal Defense",
  "Real Estate Law",
];

const stats = [
  { icon: Award, label: "Experience", value: "More Than 5+ Years" },
  { icon: Mail, label: "Email", value: "contact@example.com" },
  { icon: Phone, label: "Phone", value: "+01 23456789" },
  { icon: Printer, label: "Fax", value: "+01 23456789" },
];

const socials = [
  { label: "Facebook", char: "f", href: "#" },
  { label: "Instagram", char: "◎", href: "#" },
  { label: "LinkedIn", char: "in", href: "#" },
  { label: "WhatsApp", char: "☏", href: "#" },
];
---

<MainLayout
  title="Attorney Profile"
  description="Meet the experienced attorneys at Civitas Law. Dedicated legal professionals with proven results in criminal defense, business law, and civil litigation."
>
  <Header />
  <PageHero title="Attorney Profile" />

  <section class="atty-section">
    <div class="container">
        <div class="atty-inner">
          <div class="atty-photo shine-image reveal-left">
            <img
              src="https://civitas.divigurus.com/wp-content/uploads/2026/03/documents-contract-eyebrow-collar-formal-wear-neck-1707616-pxhere.com_11zon-scaled.jpg"
              alt="Elena M. — Personal Attorney"
              fetchpriority="high"
              decoding="async"
            />
          </div>

          <div class="atty-info reveal-right">
            <h2 class="atty-name">Elena M.</h2>
            <p class="atty-role">Personal Attorney</p>

            <div class="atty-stats">
              {
                stats.map(({ icon: Icon, label, value }) => (
                  <div class="atty-stat">
                    <span class="atty-stat__icon">
                      <Icon size={26} stroke-width={2.4} />
                    </span>
                    <div>
                      <h4>{label}</h4>
                      <p>{value}</p>
                    </div>
                  </div>
                ))
              }
            </div>

            <div class="atty-social">
              {
                socials.map((s) => (
                  <a
                    href={s.href}
                    class="atty-social__link"
                    aria-label={`Follow on ${s.label}`}
                  >
                    {s.char}
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>
  </section>

  <!-- ── About ─────────────────────────────────────────── -->
  <section class="atty-about">
    <div class="container">
      <h2>About Elena M.</h2>
      <p>
        With over 5+ years of experience in the legal industry, Elena M. has
        built a reputation for meticulous case preparation and a relentless
        commitment to client success. Specializing in Corporate & Business Law,
        she has successfully navigated complex legal landscapes for both
        individuals and corporate entities.
      </p>
      <p>
        Elena believes that effective representation starts with a deep
        understanding of the client's unique goals. By combining aggressive
        advocacy with strategic negotiation, she ensures that every client
        receives a tailored legal strategy designed to achieve the best possible
        outcome.
      </p>
    </div>
  </section>

  <!-- ── Skills + Achievements ─────────────────────────── -->
  <section class="atty-skills-section">
    <div class="container atty-skills-grid">
      <!-- Skills -->
      <div class="atty-skills-col">
        <h2>Professional Skills</h2>
        <p class="atty-skills-lead">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nulla nec
          rutrum velit. Morbi mattis tellus ante.
        </p>

        <div class="atty-bars">
          {
            skills.map((s) => (
              <div class="atty-bar-item">
                <div class="atty-bar-header">
                  <span>{s.label}</span>
                  <span class="atty-bar-pct">{s.pct}%</span>
                </div>
                <div class="atty-bar-track">
                  <div class="atty-bar-fill" data-pct={s.pct} />
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Achievements -->
      <div class="atty-achv-col">
        <h2>Achievements</h2>
        <p class="atty-skills-lead">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nulla nec
          rutrum velit. Morbi mattis tellus ante.
        </p>

        <div class="atty-achv-grid">
          {
            achievements.map(({ icon: Icon, title, desc }) => (
              <div class="atty-achv-card">
                <span class="atty-achv-card__icon">
                  <Icon size={28} />
                </span>
                <h4>{title}</h4>
                <p>{desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ── Contact form ───────────────────────────────────── -->
  <section class="atty-contact-section">
    <div class="container atty-contact-inner">
      <h2>Let's Win Together</h2>

      <form class="atty-contact-form reveal-scale">
        <div class="atty-form-row">
          <input type="text" placeholder="Name" required />
          <input
            type="tel"
            placeholder="Phone Number"
            pattern="[0-9\s\-]*"
            required
          />
        </div>
        <input type="email" placeholder="Email Address" required />
        <select required>
          <option value="">Select Service</option>
          {services.map((s) => <option value={s}>{s}</option>)}
        </select>
        <textarea placeholder="Your Message" required></textarea>
        <div class="atty-form-action">
          <button type="submit" class="practice-view-btn btn-fill-hover">
            Book Appointment <MoveRight size={16} />
          </button>
        </div>
      </form>
    </div>
  </section>
  <div class="atty-testimonials">
    <Testimonials />
  </div>

  <Footer />
</MainLayout>

<script>
  /* ── Progress bars ─────────────────────────────────── */
  const bars = document.querySelectorAll<HTMLElement>(".atty-bar-fill");
  const barObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const bar = entry.target as HTMLElement;
          bar.style.width = (bar.dataset.pct ?? "0") + "%";
          barObserver.unobserve(bar);
        }
      });
    },
    { threshold: 0.3 },
  );
  bars.forEach((bar) => barObserver.observe(bar));

  /* ── Reveal animations (slide + scale) ─────────────── */

  const reveals = document.querySelectorAll(".reveal-scale");

  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.2 },
  );

  reveals.forEach((el) => revealObserver.observe(el));
</script>
