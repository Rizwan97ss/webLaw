---
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import PageHero from "../../components/common/PageHero.astro";
import FAQ from "../../components/home/FAQ.astro";
import Clients from "../../components/home/Clients.astro";
import img642888 from "../../assets/642888.jpg";
import img1278242 from "../../assets/1278242.jpg";
import img1046502 from "../../assets/1046502.jpg";

const testimonials = [
  {
    name: "Michael R",
    role: "Personal Injury Client",
    photo: img642888.src,
    quote:
      "Their strategic approach to our complex merger saved us months of negotiation. They are more than just lawyers; they are true business partners.",
  },
  {
    name: "Sarah L",
    role: "Family Law Client",
    photo:
      img1278242.src,
    quote:
      "Their strategic approach to our complex merger saved us months of negotiation. They are more than just lawyers; they are true business partners.",
  },
  {
    name: "David K",
    role: "Corporate Law Client",
    photo:
      img1046502.src,
    quote:
      "Their strategic approach to our complex merger saved us months of negotiation. They are more than just lawyers; they are true business partners.",
  },
  {
    name: "Michael R",
    role: "Personal Injury Client",
    photo:
      img642888.src,
    quote:
      "Their strategic approach to our complex merger saved us months of negotiation. They are more than just lawyers; they are true business partners.",
  },
  {
    name: "Sarah L",
    role: "Family Law Client",
    photo:
      img1278242.src,
    quote:
      "Their strategic approach to our complex merger saved us months of negotiation. They are more than just lawyers; they are true business partners.",
  },
  {
    name: "David K",
    role: "Corporate Law Client",
    photo:
      img1046502.src,
    quote:
      "Their strategic approach to our complex merger saved us months of negotiation. They are more than just lawyers; they are true business partners.",
  },
];

const rows = [
  [testimonials[0], testimonials[1]],
  [testimonials[2], testimonials[3]],
  [testimonials[4], testimonials[5]],
];
---

<MainLayout
  title="Client Testimonials"
  description="See what our clients say about Civitas Law. Real testimonials from people we have helped navigate criminal, business, and personal legal matters."
>
  <Header />
  <PageHero title="Client Testimonials" />

  <section class="ts2-section">
    <div class="container">

      <!-- ── Section header ──────────────────────────── -->
      <div class="ts2-head">
        <div class="contact-kicker">
          <span>⚖</span>
          <span>Testimonials</span>
        </div>
        <h2>What Our Client's Say</h2>
      </div>

      <!-- ── Testimonial grid ────────────────────────── -->
      <div class="ts2-grid">
        {rows.map((row) => (
          <div class="ts2-row">
            {row.map((t) => (
              <div class="ts2-card">
                <span class="ts2-quote">&ldquo;</span>
                <div class="ts2-author">
                  <img
                    src={t.photo}
                    alt={t.name}
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="ts2-author-info">
                    <h4>{t.name}</h4>
                    <p>{t.role}</p>
                  </div>
                </div>
                <p class="ts2-text">{t.quote}</p>
              </div>
            ))}
          </div>
        ))}
      </div>

    </div>
  </section>
<FAQ/>
<Clients/>
  <Footer />
</MainLayout>
