---
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import PageHero from "../../components/common/PageHero.astro";
import img1700934 from "../../assets/1700934.jpg";
import img632090 from "../../assets/632090.jpg";
import img1700922 from "../../assets/1700922.jpg";
import img477132 from "../../assets/477132.jpg";
import img1700924 from "../../assets/1700924.jpg";
import img1701078 from "../../assets/1701078.jpg";

const images = [
  { src: img1700934.src, alt: "Legal consultation between attorneys" },
  { src: img632090.src,  alt: "Attorney working at desk" },
  { src: img1700922.src, alt: "Professional handshake in office" },
  { src: img477132.src,  alt: "Legal books and gavel" },
  { src: img1700924.src, alt: "Business professional client meeting" },
  { src: img1701078.src, alt: "Attorney portrait" },
];
---

<MainLayout
  title="Our Gallery"
  description="A look inside Civitas Law — our team, offices, and the people we serve. Committed to excellence in every case."
>
  <Header />
  <PageHero title="Our Gallery" />

  <section class="gallery-section">
    <div class="container">

      <!-- ── Header ─────────────────────────────────── -->
      <div class="gallery-head">
        <div class="contact-kicker">
          <span>⚖</span>
          <span>Firm Excellence in Focus</span>
        </div>
        <h2>A Glimpse Inside Our<br />Professional Environment</h2>
      </div>

      <!-- ── Grid ──────────────────────────────────── -->
      <div class="gallery-grid">
        {images.map((img, i) => (
          <button
            class="gallery-item"
            data-src={img.src}
            data-alt={img.alt}
            aria-label={`Open image: ${img.alt}`}
            type="button"
          >
            <img
              src={img.src}
              alt={img.alt}
              loading={i === 0 ? "eager" : "lazy"}
              decoding="async"
            />
            <div class="gallery-overlay">
              <span class="gallery-zoom" aria-hidden="true">&#x2315;</span>
            </div>
          </button>
        ))}
      </div>

    </div>
  </section>

  <!-- ── Lightbox ───────────────────────────────────── -->
  <dialog id="lightbox" class="lightbox" aria-modal="true" aria-label="Image lightbox">
    <button class="lightbox-close" id="lightboxClose" type="button" aria-label="Close lightbox">&times;</button>
    <img id="lightboxImg" src="" alt="" />
  </dialog>

  <Footer />
</MainLayout>

<script>
  const items = document.querySelectorAll<HTMLButtonElement>(".gallery-item");
  const lightbox = document.getElementById("lightbox") as HTMLDialogElement | null;
  const lightboxImg = document.getElementById("lightboxImg") as HTMLImageElement | null;
  const lightboxClose = document.getElementById("lightboxClose");

  function openLightbox(src: string, alt: string) {
    if (!lightbox || !lightboxImg) return;
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.showModal();
  }

  function closeLightbox() {
    lightbox?.close();
    if (lightboxImg) {
      lightboxImg.src = "";
      lightboxImg.alt = "";
    }
  }

  items.forEach((item) => {
    item.addEventListener("click", () => {
      const src = item.dataset.src ?? "";
      const alt = item.dataset.alt ?? "";
      openLightbox(src, alt);
    });
  });

  lightboxClose?.addEventListener("click", closeLightbox);

  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox();
  });
</script>
