---
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import PageHero from "../../components/common/PageHero.astro";
import { Phone, Mail, MapPin, Gavel } from "lucide-astro";

const services = [
  "Corporate & Business Law",
  "Family Law & Mediation",
  "Personal Injury Litigation",
  "Estate Planning & Probate",
  "Criminal Defense",
  "Real Estate Law",
];

const locations = [
  {
    id: "london",
    label: "London",
    phone: "+01 23456789",
    email: "contact@example.com",
    address: "9976 Reynalda Ways, London",
    mapSrc:
      "https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d37912432.365362324!2d-4.473772!3d54.55128!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x25a3b1142c791a9%3A0xc4f8a0433288257a!2sUnited%20Kingdom!5e0!3m2!1sen!2sbd!4v1774210451357!5m2!1sen!2sbd",
  },
  {
    id: "singapore",
    label: "Singapore",
    phone: "+98 76543210",
    email: "demo@example.com",
    address: "90 Bukit Batok, Singapore",
    mapSrc:
      "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d510562.31415020354!2d103.51456240323388!3d1.3146649690516565!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31da11238a8b9375%3A0x887869cf52abf5c4!2sSingapore!5e0!3m2!1sen!2sbd!4v1775980005830!5m2!1sen!2sbd",
  },
];
---

<MainLayout title="Contact Us - Civitas Law">
  <Header />
  <PageHero title="Schedule Your Consultation" />

  <section class="c2-section">
    <div class="container c2-grid">

      <!-- ── Left: Form ─────────────────────────────── -->
      <div class="c2-form-col">
        <div class="contact-kicker">
          <Gavel size={16} />
          <span>Have Any Question?</span>
        </div>

        <h2 class="c2-heading">Contact Us For More Information</h2>

        <form class="contact-form c2-form" id="c2-form" novalidate>
          <div class="field-wrap">
            <input type="text" name="name" placeholder="Name" />
            <span class="field-error"></span>
          </div>
          <div class="field-wrap">
            <input type="tel" name="phone" placeholder="Phone Number" />
            <span class="field-error"></span>
          </div>
          <div class="field-wrap">
            <input type="email" name="email" placeholder="Email Address" />
            <span class="field-error"></span>
          </div>
          <div class="field-wrap">
            <select name="service">
              <option value="">Select Service</option>
              {services.map((s) => <option value={s}>{s}</option>)}
            </select>
            <span class="field-error"></span>
          </div>
          <div class="field-wrap">
            <textarea name="message" placeholder="Your Message"></textarea>
            <span class="field-error"></span>
          </div>
          <div class="form-action">
            <button type="submit" class="btn-fill-hover">
              Book Appointment <span>→</span>
            </button>
          </div>
          <p class="form-success" style="display:none;color:#22c55e;font-weight:600;">
            Thank you! We'll be in touch shortly.
          </p>
        </form>
      </div>

      <!-- ── Right: Tabs + Info + Map ───────────────── -->
      <div class="c2-info-col">

        <!-- Tab buttons -->
        <div class="c2-tabs" role="tablist">
          {locations.map((loc, i) => (
            <button
              class={`c2-tab${i === 0 ? " is-active" : ""}`}
              data-tab={loc.id}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              aria-controls={`panel-${loc.id}`}
              type="button"
            >
              {loc.label}
            </button>
          ))}
        </div>

        <!-- Tab panels -->
        {locations.map((loc, i) => (
          <div
            class={`c2-panel${i === 0 ? " is-active" : ""}`}
            id={`panel-${loc.id}`}
            role="tabpanel"
          >
            <!-- Contact blurbs -->
            <div class="c2-blurb-row">
              <div class="c2-blurb">
                <span class="c2-blurb__icon"><Phone size={20} /></span>
                <div>
                  <h4>Phone Number</h4>
                  <p>{loc.phone}</p>
                </div>
              </div>

              <div class="c2-blurb">
                <span class="c2-blurb__icon"><Mail size={20} /></span>
                <div>
                  <h4>Email Address</h4>
                  <p>{loc.email}</p>
                </div>
              </div>

              <div class="c2-blurb c2-blurb--full">
                <span class="c2-blurb__icon"><MapPin size={20} /></span>
                <div>
                  <h4>Office Address</h4>
                  <p>{loc.address}</p>
                </div>
              </div>
            </div>

            <!-- Map -->
            <div class="c2-map">
              <iframe
                src={loc.mapSrc}
                loading="lazy"
                allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<script>
  const c2Form = document.getElementById("c2-form") as HTMLFormElement | null;
  if (c2Form) {
    function showErr(el: HTMLElement, msg: string) {
      el.classList.add("invalid");
      const span = el.nextElementSibling as HTMLElement;
      if (span) span.textContent = msg;
    }
    function clearErr(el: HTMLElement) {
      el.classList.remove("invalid");
      const span = el.nextElementSibling as HTMLElement;
      if (span) span.textContent = "";
    }
    c2Form.querySelectorAll("input,select,textarea").forEach((el) => {
      el.addEventListener("input", () => clearErr(el as HTMLElement));
      el.addEventListener("change", () => clearErr(el as HTMLElement));
    });
    c2Form.addEventListener("submit", (e) => {
      e.preventDefault();
      let ok = true;
      const name = c2Form.querySelector<HTMLInputElement>('[name="name"]')!;
      const phone = c2Form.querySelector<HTMLInputElement>('[name="phone"]')!;
      const email = c2Form.querySelector<HTMLInputElement>('[name="email"]')!;
      const service = c2Form.querySelector<HTMLSelectElement>('[name="service"]')!;
      const message = c2Form.querySelector<HTMLTextAreaElement>('[name="message"]')!;

      if (name.value.trim().length < 2) { showErr(name, "Name must be at least 2 characters."); ok = false; }
      if (!/^[\d\s\-\+\(\)]{7,}$/.test(phone.value.trim())) { showErr(phone, "Enter a valid phone number (digits, min 7)."); ok = false; }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim())) { showErr(email, "Enter a valid email address."); ok = false; }
      if (!service.value) { showErr(service, "Please select a service."); ok = false; }
      if (message.value.trim().length < 10) { showErr(message, "Message must be at least 10 characters."); ok = false; }

      if (ok) {
        const success = c2Form.querySelector<HTMLElement>(".form-success")!;
        c2Form.reset();
        success.style.display = "block";
        setTimeout(() => { success.style.display = "none"; }, 5000);
      }
    });
  }
</script>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.c2-tab');
  const panels = document.querySelectorAll<HTMLElement>('.c2-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;

      tabs.forEach((t) => {
        t.classList.remove('is-active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach((p) => p.classList.remove('is-active'));

      tab.classList.add('is-active');
      tab.setAttribute('aria-selected', 'true');
      document.getElementById(`panel-${target}`)?.classList.add('is-active');
    });
  });
</script>
