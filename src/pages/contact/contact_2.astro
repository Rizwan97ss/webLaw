---
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import PageHero from "../../components/common/PageHero.astro";
import { Phone, Mail, MapPin, Gavel } from "lucide-astro";

const services = [
  "Corporate & Business Law",
  "Family Law & Mediation",
  "Personal Injury Litigation",
  "Estate Planning & Probate",
  "Criminal Defense",
  "Real Estate Law",
];

const locations = [
  {
    id: "london",
    label: "London",
    phone: "+01 23456789",
    email: "contact@example.com",
    address: "9976 Reynalda Ways, London",
    mapSrc:
      "https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d37912432.365362324!2d-4.473772!3d54.55128!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x25a3b1142c791a9%3A0xc4f8a0433288257a!2sUnited%20Kingdom!5e0!3m2!1sen!2sbd!4v1774210451357!5m2!1sen!2sbd",
  },
  {
    id: "singapore",
    label: "Singapore",
    phone: "+98 76543210",
    email: "demo@example.com",
    address: "90 Bukit Batok, Singapore",
    mapSrc:
      "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d510562.31415020354!2d103.51456240323388!3d1.3146649690516565!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31da11238a8b9375%3A0x887869cf52abf5c4!2sSingapore!5e0!3m2!1sen!2sbd!4v1775980005830!5m2!1sen!2sbd",
  },
];
---

<MainLayout title="Contact Us - Civitas Law">
  <Header />
  <PageHero title="Schedule Your Consultation" />

  <section class="c2-section">
    <div class="container c2-grid">

      <!-- ── Left: Form ─────────────────────────────── -->
      <div class="c2-form-col">
        <div class="contact-kicker">
          <Gavel size={16} />
          <span>Have Any Question?</span>
        </div>

        <h2 class="c2-heading">Contact Us For More Information</h2>

        <form class="contact-form c2-form">
          <input type="text" placeholder="Name" required />
          <input type="tel" placeholder="Phone Number" pattern="[0-9\s\-]*" required />
          <input type="email" placeholder="Email Address" required />

          <select required>
            <option value="">Select Service</option>
            {services.map((s) => <option value={s}>{s}</option>)}
          </select>

          <textarea placeholder="Your Message" required></textarea>

          <div class="form-action">
            <button type="submit" class="btn-fill-hover">
              Book Appointment <span>→</span>
            </button>
          </div>
        </form>
      </div>

      <!-- ── Right: Tabs + Info + Map ───────────────── -->
      <div class="c2-info-col">

        <!-- Tab buttons -->
        <div class="c2-tabs" role="tablist">
          {locations.map((loc, i) => (
            <button
              class={`c2-tab${i === 0 ? " is-active" : ""}`}
              data-tab={loc.id}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              aria-controls={`panel-${loc.id}`}
              type="button"
            >
              {loc.label}
            </button>
          ))}
        </div>

        <!-- Tab panels -->
        {locations.map((loc, i) => (
          <div
            class={`c2-panel${i === 0 ? " is-active" : ""}`}
            id={`panel-${loc.id}`}
            role="tabpanel"
          >
            <!-- Contact blurbs -->
            <div class="c2-blurb-row">
              <div class="c2-blurb">
                <span class="c2-blurb__icon"><Phone size={20} /></span>
                <div>
                  <h4>Phone Number</h4>
                  <p>{loc.phone}</p>
                </div>
              </div>

              <div class="c2-blurb">
                <span class="c2-blurb__icon"><Mail size={20} /></span>
                <div>
                  <h4>Email Address</h4>
                  <p>{loc.email}</p>
                </div>
              </div>

              <div class="c2-blurb c2-blurb--full">
                <span class="c2-blurb__icon"><MapPin size={20} /></span>
                <div>
                  <h4>Office Address</h4>
                  <p>{loc.address}</p>
                </div>
              </div>
            </div>

            <!-- Map -->
            <div class="c2-map">
              <iframe
                src={loc.mapSrc}
                loading="lazy"
                allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  /* ── Section ─────────────────────────────────────── */
  .c2-section {
    padding: 80px 0;
  }

  .c2-grid {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 3fr);
    gap: 50px;
    align-items: start;
  }

  /* ── Left column ─────────────────────────────────── */
  .c2-form-col {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .c2-heading {
    margin: 0;
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    font-weight: 600;
    color: var(--gcid-heading-color, #101932);
    line-height: 1.2;
  }

  /* Reset components.css slide-in animation — no IntersectionObserver here */
  .c2-form {
    opacity: 1 !important;
    transform: none !important;
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 0;
    background: none;
    border-radius: 0;
  }

  /* ── Right column ────────────────────────────────── */
  .c2-info-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ── Tabs ────────────────────────────────────────── */
  .c2-tabs {
    display: flex;
    gap: 0;
    border-radius: 8px;
    overflow: hidden;
    align-self: flex-start;
    border: 1.5px solid #ffc342;
  }

  .c2-tab {
    padding: 12px 28px;
    border: 0;
    background: #fff;
    color: #242424;
    font-family: var(--font-cabin, "Cabin", sans-serif);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .c2-tab.is-active {
    background: #ffc342;
    color: #101932;
    font-weight: 600;
  }

  .c2-tab:hover:not(.is-active) {
    background: #fff9e8;
  }

  /* ── Tab panels ──────────────────────────────────── */
  .c2-panel {
    display: none;
    flex-direction: column;
    gap: 24px;
  }

  .c2-panel.is-active {
    display: flex;
  }

  /* ── Blurb row ───────────────────────────────────── */
  .c2-blurb-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .c2-blurb--full {
    grid-column: 1 / -1;
  }

  .c2-blurb {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 18px;
    border-radius: 10px;
    background: color-mix(in srgb, #ffc342 10%, white);
  }

  .c2-blurb__icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #ffc342;
    color: #101932;
  }

  .c2-blurb h4 {
    margin: 0 0 4px;
    font-size: 15px;
    font-weight: 600;
    color: #101932;
  }

  .c2-blurb p {
    margin: 0;
    font-size: 14px;
    color: #505658;
    font-family: var(--font-cabin, "Cabin", sans-serif);
  }

  /* ── Map ─────────────────────────────────────────── */
  .c2-map iframe {
    width: 100%;
    height: 350px;
    border: 0;
    border-radius: 10px;
    display: block;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 980px) {
    .c2-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 640px) {
    .c2-section {
      padding: 40px 0;
    }

    .c2-blurb-row {
      grid-template-columns: 1fr;
    }

    .c2-blurb--full {
      grid-column: auto;
    }

    .c2-tab {
      padding: 10px 18px;
      font-size: 14px;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.c2-tab');
  const panels = document.querySelectorAll<HTMLElement>('.c2-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;

      tabs.forEach((t) => {
        t.classList.remove('is-active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach((p) => p.classList.remove('is-active'));

      tab.classList.add('is-active');
      tab.setAttribute('aria-selected', 'true');
      document.getElementById(`panel-${target}`)?.classList.add('is-active');
    });
  });
</script>
