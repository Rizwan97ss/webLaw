---
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import PageHero from "../../components/common/PageHero.astro";
import { User, Tag, CalendarDays } from "lucide-astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const recentPosts = allPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const categories = [...new Set(allPosts.map((p) => p.data.category))];

// used in template for category href
const toSlug = (str: string) =>
  str.toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, "");

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---

<MainLayout title={`${post.data.title} - Civitas Law`}>
  <Header />
  <PageHero title="Blog Details" />

  <section class="bd-section">
    <div class="container">
      <div class="bd-layout">

        <!-- ── Main article ────────────────────────────────── -->
        <main class="bd-main">

          <!-- Hero image -->
          <div class="bd-img-wrap">
            <img src={post.data.image} alt={post.data.title} />
          </div>

          <!-- Meta row -->
          <div class="bd-meta">
            <span class="bd-meta__item">
              <CalendarDays size={14} strokeWidth={2.5} />
              {fmt(post.data.pubDate)}
            </span>
            <span class="bd-meta__item">
              <User size={14} strokeWidth={2.5} />
              {post.data.author}
            </span>
            <a href={`/blog/category/${toSlug(post.data.category)}`} class="bd-meta__item bd-meta__item--link">
              <Tag size={14} strokeWidth={2.5} />
              {post.data.category}
            </a>
          </div>

          <!-- Title -->
          <h1 class="bd-title">{post.data.title}</h1>

          <!-- Markdown body -->
          <div class="bd-body">
            <Content />
          </div>

        </main>

        <!-- ── Sidebar ─────────────────────────────────────── -->
        <aside class="bd-sidebar">
          <div class="bd-sidebar-inner">

            <!-- Browse Categories -->
            <div class="sidebar-widget">
              <h3 class="sidebar-widget__title">Browse Categories</h3>
              <ul class="sidebar-cat-list">
                {categories.map((cat) => (
                  <li class={cat === post.data.category ? "active" : ""}>
                    <a href={`/blog/category/${toSlug(cat)}`}>
                      <span class="cat-arrow">→</span>
                      {cat}
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Recent Posts -->
            {recentPosts.length > 0 && (
              <div class="sidebar-widget">
                <h3 class="sidebar-widget__title">Recent Post</h3>
                <ul class="sidebar-recent-list">
                  {recentPosts.map((rp) => (
                    <li>
                      <a href={`/blog/${rp.id}`} class="sidebar-recent__img-wrap">
                        <img src={rp.data.image} alt={rp.data.title} loading="lazy" />
                      </a>
                      <div class="sidebar-recent__info">
                        <a href={`/blog/${rp.id}`} class="sidebar-recent__title">
                          {rp.data.title}
                        </a>
                        <span class="sidebar-recent__date">
                          <CalendarDays size={13} strokeWidth={2} />
                          {fmt(rp.data.pubDate)}
                        </span>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            )}

          </div><!-- /bd-sidebar-inner -->
        </aside>

      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  /* ── Section ─────────────────────────────────────────── */
  .bd-section {
    padding: 80px 0;
    background: #fff;
  }

  /* ── 2-column layout ─────────────────────────────────── */
  .bd-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 40px;
    align-items: start;
  }

  /* ── Main ────────────────────────────────────────────── */
  .bd-main {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  /* Hero image */
  .bd-img-wrap {
    border-radius: 14px;
    overflow: hidden;
  }

  .bd-img-wrap img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  /* Meta row */
  .bd-meta {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .bd-meta__item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--gcid-body-color, #505658);
  }

  .bd-meta__item :global(svg) {
    color: var(--gcid-primary-color, #ffc342);
    flex-shrink: 0;
  }

  .bd-meta__item--link {
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .bd-meta__item--link:hover {
    color: var(--gcid-primary-color, #ffc342);
  }

  /* Title */
  .bd-title {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--gcid-heading-color, #101932);
    line-height: 1.25;
  }

  /* ── Article body (markdown content) ────────────────── */
  .bd-body {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .bd-body :global(p) {
    margin: 0;
    font-size: 16px;
    line-height: 1.8;
    color: var(--gcid-body-color, #505658);
  }

  .bd-body :global(h2),
  .bd-body :global(h3) {
    margin: 6px 0 0;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 700;
    color: var(--gcid-heading-color, #101932);
    line-height: 1.3;
  }

  .bd-body :global(ul),
  .bd-body :global(ol) {
    margin: 0;
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bd-body :global(ul li),
  .bd-body :global(ol li) {
    position: relative;
    padding-left: 30px;
    font-size: 16px;
    line-height: 1.6;
    color: var(--gcid-body-color, #505658);
  }

  .bd-body :global(ul li::before) {
    content: "✓";
    position: absolute;
    left: 0;
    top: 4px;
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--gcid-primary-color, #ffc342);
    color: #101932;
    font-size: 10px;
    font-weight: 700;
  }

  .bd-body :global(ol) {
    counter-reset: ol-counter;
  }

  .bd-body :global(ol li) {
    counter-increment: ol-counter;
  }

  .bd-body :global(ol li::before) {
    content: counter(ol-counter);
    position: absolute;
    left: 0;
    top: 2px;
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--gcid-primary-color, #ffc342);
    color: #101932;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
  }

  .bd-body :global(strong) {
    color: var(--gcid-heading-color, #101932);
    font-weight: 700;
  }

  /* ── Sidebar ─────────────────────────────────────────── */
  .bd-sidebar {
    align-self: stretch;
  }

  .bd-sidebar-inner {
    position: sticky;
    top: calc(var(--navbar-h, 80px) + 24px);
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .sidebar-widget {
    background: #fff8e8;
    border: 1px solid rgba(255, 196, 66, 0.15);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.04);
  }

  .sidebar-widget__title {
    margin: 0;
    padding: 20px 24px;
    background: var(--gcid-primary-color, #ffc342);
    color: var(--gcid-heading-color, #101932);
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.2;
  }

  /* Category list */
  .sidebar-cat-list {
    margin: 0;
    padding: 12px 20px 16px;
    list-style: none;
  }

  .sidebar-cat-list li {
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    transition: background-color 0.3s ease;
  }

  .sidebar-cat-list li:last-child {
    border-bottom: 0;
  }

  .sidebar-cat-list li a {
    padding: 18px 0;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--gcid-heading-color, #101932);
    font-family: var(--font-cabin);
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.3s ease, padding-left 0.3s ease;
  }

  .sidebar-cat-list li:hover a {
    padding-left: 8px;
    color: var(--gcid-primary-color, #ffc342);
  }

  .cat-arrow {
    color: var(--gcid-primary-color, #ffc342);
    font-size: 18px;
    font-weight: 700;
    line-height: 1;
  }

  /* Recent posts */
  .sidebar-recent-list {
    margin: 0;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 22px;
    list-style: none;
  }

  .sidebar-recent-list li {
    display: grid;
    grid-template-columns: 95px 1fr;
    gap: 15px;
    align-items: start;
  }

  .sidebar-recent__img-wrap {
    width: 95px;
    height: 75px;
    display: block;
    overflow: hidden;
    border-radius: 10px;
  }

  .sidebar-recent__img-wrap img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
    transition: transform 0.4s ease;
  }

  .sidebar-recent__img-wrap:hover img {
    transform: scale(1.08);
  }

  .sidebar-recent__info {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sidebar-recent__title {
    color: var(--gcid-heading-color, #101932);
    display: -webkit-box;
    overflow: hidden;
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.35;
    text-decoration: none;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    transition: color 0.3s ease;
  }

  .sidebar-recent__title:hover {
    color: var(--gcid-primary-color, #ffc342);
  }

  .sidebar-recent__date {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--gcid-primary-color, #ffc342);
    font-family: var(--font-cabin);
    font-size: 13px;
    font-weight: 600;
    line-height: 1.2;
  }

  .sidebar-recent__date :global(svg) {
    flex-shrink: 0;
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 1100px) {
    .bd-layout {
      grid-template-columns: 1fr 300px;
      gap: 28px;
    }

    .bd-img-wrap img {
      height: 340px;
    }
  }

  @media (max-width: 767px) {
    .bd-section {
      padding: 40px 0;
    }

    .bd-layout {
      grid-template-columns: 1fr;
    }

    .bd-sidebar-inner {
      position: static;
    }

    .bd-img-wrap img {
      height: 260px;
    }
  }
</style>
