---
import { getCollection } from "astro:content";
import MainLayout from "../../../layouts/MainLayout.astro";
import Header from "../../../components/layout/Header.astro";
import Footer from "../../../components/layout/Footer.astro";
import PageHero from "../../../components/common/PageHero.astro";
import { User, Tag, CalendarDays, MoveRight } from "lucide-astro";

const toSlug = (str: string) =>
  str.toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, "");

export async function getStaticPaths() {
  const toSlug = (str: string) =>
    str.toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, "");

  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const categories = [...new Set(allPosts.map((p) => p.data.category))];

  return categories.map((cat) => ({
    params: { category: toSlug(cat) },
    props: { categoryName: cat },
  }));
}

const { categoryName } = Astro.props;
const { category } = Astro.params;

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const allSorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts = allSorted.filter((p) => p.data.category === categoryName);
const categories = [...new Set(allSorted.map((p) => p.data.category))];

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---

<MainLayout
  title={`${categoryName} — Legal Insights`}
  description={`Read Civitas Law articles in the ${categoryName} category. Expert legal perspectives to help you understand your rights and options.`}
>
  <Header />
  <PageHero title={categoryName} />

  <section class="blog-section">
    <div class="container">
      <div class="blog-layout">

        <!-- Blog Grid -->
        <div class="blog-grid">
          {posts.length === 0 ? (
            <p class="no-posts">No posts found in this category.</p>
          ) : (
            posts.map((post) => (
              <article class="blog-card">
                <div class="blog-card__img-wrap">
                  <a href={`/blog/${post.id}`}>
                    <img src={post.data.image} alt={post.data.title} loading="lazy" />
                  </a>
                  <span class="blog-card__date">{fmt(post.data.pubDate)}</span>
                </div>

                <div class="blog-card__body">
                  <div class="blog-card__meta">
                    <span class="blog-card__meta-item">
                      <User size={15} strokeWidth={2.5} />
                      {post.data.author}
                    </span>
                    <span class="blog-card__meta-item">
                      <Tag size={15} strokeWidth={2.5} />
                      {post.data.category}
                    </span>
                  </div>

                  <h2 class="blog-card__title">
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h2>

                  <a href={`/blog/${post.id}`} class="blog-card__btn">
                    Read More
                    <MoveRight size={16} />
                  </a>
                </div>
              </article>
            ))
          )}
        </div>

        <!-- Sidebar -->
        <aside class="blog-sidebar">
          <div class="blog-sidebar-inner">

            <!-- Browse Categories -->
            <div class="sidebar-widget">
              <h3 class="sidebar-widget__title">Browse Categories</h3>
              <ul class="sidebar-cat-list">
                {categories.map((cat) => (
                  <li class={cat === categoryName ? "active" : ""}>
                    <a href={`/blog/category/${toSlug(cat)}`}>
                      <MoveRight size={14} />
                      {cat}
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Recent Posts -->
            <div class="sidebar-widget">
              <h3 class="sidebar-widget__title">Recent Post</h3>
              <ul class="sidebar-recent-list">
                {allSorted.map((post) => (
                  <li>
                    <a href={`/blog/${post.id}`} class="sidebar-recent__img-wrap">
                      <img src={post.data.image} alt={post.data.title} loading="lazy" />
                    </a>
                    <div class="sidebar-recent__info">
                      <a href={`/blog/${post.id}`} class="sidebar-recent__title">
                        {post.data.title}
                      </a>
                      <span class="sidebar-recent__date">
                        <CalendarDays size={13} strokeWidth={2} />
                        {fmt(post.data.pubDate)}
                      </span>
                    </div>
                  </li>
                ))}
              </ul>
            </div>

          </div><!-- /blog-sidebar-inner -->
        </aside>

      </div>
    </div>
  </section>

  <Footer />
</MainLayout>
