---
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import PageHero from "../../components/common/PageHero.astro";
import { User, Tag, Calendar } from "lucide-astro";

const post = {
  image: "https://civitas.divigurus.com/wp-content/uploads/2026/04/writing-word-pen-sign-key-commitment-859219-pxhere.com-1-scaled.jpg",
  title: "Trusted Legal Solutions for Your Complex Cases",
  date: "Mar 2, 2026",
  author: "By Civitas Law",
  category: "Family Law",
};

const categories = ["Family Law", "Criminal Law", "Real Estate Law"];

const recentPosts = [
  {
    title: "Protecting Your Rights with Professional Legal Services",
    date: "Mar 28, 2026",
    href: "/blog/blog-details",
    image: "https://civitas.divigurus.com/wp-content/uploads/2026/04/wood-guitar-red-hammer-color-piano-801066-pxhere.com-1-scaled.jpg",
  },
  {
    title: "Expert Lawyer Guidance for Business and Personal Matters",
    date: "Mar 10, 2026",
    href: "/blog/blog-details",
    image: "https://civitas.divigurus.com/wp-content/uploads/2026/04/wood-hammer-rule-justice-horizontal-court-719590-pxhere.com-1-scaled.jpg",
  },
  {
    title: "Trusted Legal Solutions for Your Complex Cases",
    date: "Mar 2, 2026",
    href: "/blog/blog-details",
    image: "https://civitas.divigurus.com/wp-content/uploads/2026/04/writing-word-pen-sign-key-commitment-859219-pxhere.com-1-scaled.jpg",
  },
];
---

<MainLayout title="Blog Details - Civitas Law">
  <Header />
  <PageHero title="Blog Details" />

  <section class="bd-section">
    <div class="container">
      <div class="bd-layout">

        <!-- ── Main article ────────────────────────────────── -->
        <main class="bd-main">

          <!-- Hero image -->
          <div class="bd-img-wrap">
            <img src={post.image} alt={post.title} />
          </div>

          <!-- Meta row -->
          <div class="bd-meta">
            <span class="bd-meta__item">
              <Calendar size={14} strokeWidth={2.5} />
              {post.date}
            </span>
            <span class="bd-meta__item">
              <User size={14} strokeWidth={2.5} />
              {post.author}
            </span>
            <span class="bd-meta__item">
              <Tag size={14} strokeWidth={2.5} />
              {post.category}
            </span>
          </div>

          <!-- Title -->
          <h1 class="bd-title">{post.title}</h1>

          <!-- Article body -->
          <div class="bd-body">
            <p>
              Navigating the legal landscape can often feel like walking through a labyrinth. When the stakes are low, a simple map might suffice. However, when you are faced with a complex case — one involving intricate financial structures, multi-party disputes, or high-stakes litigation — the margin for error disappears entirely.
            </p>

            <p>
              But what truly defines a trusted solution in the modern legal era? It is more than just a firm with a high success rate; it is the synthesis of deep expertise, strategic transparency, and an unwavering commitment to the client's long-term objectives. At Civitas Law, we understand this distinction and build every engagement around it.
            </p>

            <h3>Understanding the Anatomy of Complexity</h3>

            <p>A case is typically deemed complex when it transcends standard legal procedures. This might include:</p>

            <ul>
              <li><strong>Commercial Litigation:</strong> Shareholder disputes or breach of contract issues that threaten a company's survival.</li>
              <li><strong>Specialized Advocacy:</strong> Cases involving emerging regulations, intellectual property, or cross-border jurisdictional hurdles.</li>
              <li><strong>High-Asset Disputes:</strong> Where valuation of assets and tax implications requires forensic-level detail.</li>
            </ul>

            <h3>The Pillars of Trustworthy Representation</h3>

            <ol>
              <li><strong>Strategic Foresight:</strong> Trusted legal solutions are built on exhaustive research and planning for every possible outcome.</li>
              <li><strong>Transparent Communication:</strong> Clients need to understand what is happening and why it is happening, in plain language.</li>
              <li><strong>Tailored Resource Allocation:</strong> Complex cases often require forensic accountants, expert witnesses, and seasoned investigators working as a coordinated team.</li>
            </ol>

            <h3>Moving Beyond the Verdict</h3>

            <p>
              Ultimately, trusted legal solutions are about more than winning a single case; they are about protecting a legacy and providing a foundation for future stability. Our attorneys remain available long after the gavel falls, because we understand that the best outcomes are built over time, not just in the courtroom.
            </p>
          </div>

        </main>

        <!-- ── Sidebar ─────────────────────────────────────── -->
        <aside class="bd-sidebar">
          <div class="bd-sidebar-inner">

          <!-- Browse Categories -->
          <div class="sidebar-widget">
            <h3 class="sidebar-widget__title">Browse Categories</h3>
            <ul class="sidebar-cat-list">
              {categories.map((cat) => (
                <li>
                  <a href="#">{cat}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Recent Posts -->
          <div class="sidebar-widget">
            <h3 class="sidebar-widget__title">Recent Post</h3>
            <ul class="sidebar-recent-list">
              {recentPosts.map((rp) => (
                <li>
                  <a href={rp.href} class="sidebar-recent__img-wrap">
                    <img src={rp.image} alt={rp.title} loading="lazy" />
                  </a>
                  <div class="sidebar-recent__info">
                    <a href={rp.href} class="sidebar-recent__title">{rp.title}</a>
                    <span class="sidebar-recent__date">{rp.date}</span>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          </div><!-- /bd-sidebar-inner -->
        </aside>

      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  /* ── Section ─────────────────────────────────────────── */
  .bd-section {
    padding: 80px 0;
    background: #fff;
  }

  /* ── 2-column layout ─────────────────────────────────── */
  .bd-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 40px;
    align-items: start;
  }

  /* ── Main ────────────────────────────────────────────── */
  .bd-main {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  /* Hero image */
  .bd-img-wrap {
    border-radius: 10px;
    overflow: hidden;
  }

  .bd-img-wrap img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  /* Meta row */
  .bd-meta {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .bd-meta__item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--gcid-body-color, #505658);
  }

  .bd-meta__item :global(svg) {
    color: var(--gcid-primary-color, #ffc342);
    flex-shrink: 0;
  }

  /* Title */
  .bd-title {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--gcid-heading-color, #101932);
    line-height: 1.25;
  }

  /* ── Article body ────────────────────────────────────── */
  .bd-body {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .bd-body p {
    margin: 0;
    font-size: 16px;
    line-height: 1.8;
    color: var(--gcid-body-color, #505658);
  }

  .bd-body h3 {
    margin: 6px 0 0;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 700;
    color: var(--gcid-heading-color, #101932);
    line-height: 1.3;
  }

  .bd-body ul,
  .bd-body ol {
    margin: 0;
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bd-body ul li,
  .bd-body ol li {
    position: relative;
    padding-left: 28px;
    font-size: 16px;
    line-height: 1.6;
    color: var(--gcid-body-color, #505658);
  }

  .bd-body ul li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 4px;
    width: 18px;
    height: 18px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--gcid-primary-color, #ffc342);
    color: #101932;
    font-size: 10px;
    font-weight: 700;
  }

  .bd-body ol {
    counter-reset: ol-counter;
  }

  .bd-body ol li {
    counter-increment: ol-counter;
  }

  .bd-body ol li::before {
    content: counter(ol-counter);
    position: absolute;
    left: 0;
    top: 2px;
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--gcid-primary-color, #ffc342);
    color: #101932;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
  }

  /* ── Sidebar ─────────────────────────────────────────── */
  .bd-sidebar {
    min-height: 100%;
  }

  .bd-sidebar-inner {
    position: sticky;
    top: calc(var(--navbar-h, 80px) + 24px);
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .sidebar-widget {
    background: color-mix(in srgb, var(--gcid-primary-color, #ffc342) 10%, white);
    border-radius: 10px;
    padding: 24px;
  }

  .sidebar-widget__title {
    margin: 0 0 18px;
    font-size: 18px;
    font-weight: 700;
    color: var(--gcid-heading-color, #101932);
    padding-bottom: 12px;
    border-bottom: 2px solid var(--gcid-primary-color, #ffc342);
  }

  /* Category list */
  .sidebar-cat-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .sidebar-cat-list li {
    position: relative;
    padding-left: 22px;
    border-bottom: 1px solid rgba(0,0,0,0.1);
    padding-bottom: 10px;
    margin-bottom: 10px;
    transition: margin-left 0.3s;
  }

  .sidebar-cat-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  .sidebar-cat-list li::before {
    content: "›";
    position: absolute;
    left: 0;
    top: 0;
    font-size: 18px;
    font-weight: 700;
    color: var(--gcid-primary-color, #ffc342);
    line-height: 1.3;
  }

  .sidebar-cat-list li:hover {
    margin-left: 6px;
  }

  .sidebar-cat-list li a {
    font-size: 14px;
    font-weight: 600;
    color: var(--gcid-heading-color, #101932);
    text-decoration: none;
    transition: color 0.3s;
  }

  .sidebar-cat-list li:hover a {
    color: var(--gcid-primary-color, #ffc342);
  }

  /* Recent posts */
  .sidebar-recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sidebar-recent-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .sidebar-recent__img-wrap {
    flex-shrink: 0;
    display: block;
    width: 80px;
    height: 60px;
    overflow: hidden;
    border-radius: 6px;
  }

  .sidebar-recent__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform 0.3s;
  }

  .sidebar-recent__img-wrap:hover img {
    transform: scale(1.08);
  }

  .sidebar-recent__info {
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-width: 0;
  }

  .sidebar-recent__title {
    font-size: 13px;
    font-weight: 600;
    color: var(--gcid-heading-color, #101932);
    text-decoration: none;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.3s;
  }

  .sidebar-recent__title:hover {
    color: var(--gcid-primary-color, #ffc342);
  }

  .sidebar-recent__date {
    font-size: 12px;
    color: var(--gcid-body-color, #505658);
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 980px) {
    .bd-layout {
      grid-template-columns: 1fr 260px;
      gap: 28px;
    }

    .bd-img-wrap img {
      height: 320px;
    }
  }

  @media (max-width: 767px) {
    .bd-section {
      padding: 40px 0;
    }

    .bd-layout {
      grid-template-columns: 1fr;
    }

    .bd-sidebar {
      position: static;
    }

    .bd-img-wrap img {
      height: 240px;
    }
  }
</style>
