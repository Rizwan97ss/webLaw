---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import PageHero from "../../components/common/PageHero.astro";
import BlogCard from "../../components/cards/BlogCard.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);

const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<MainLayout title="Blog - Civitas Law">
  <Header />

  <PageHero
    eyebrow="Legal Insights"
    title="Our Blog"
    description="Helpful legal articles, practical guidance, and firm updates."
  />

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {sortedPosts.map((post) => (
          <BlogCard
            item={{
              title: post.data.title,
              slug: post.slug,
              image: post.data.image,
              date: post.data.pubDate.toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                year: "numeric",
              }),
              author: post.data.author,
              category: post.data.category,
            }}
          />
        ))}
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>