---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import PageHero from "../../components/common/PageHero.astro";
import { User, Tag, CalendarDays } from "lucide-astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const categories = [...new Set(posts.map((p) => p.data.category))];

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---

<MainLayout title="Blog - Civitas Law">
  <Header />
  <PageHero title="Our Blog" />

  <section class="blog-section">
    <div class="container">
      <div class="blog-layout">
        <div class="blog-grid">
          {posts.map((post) => (
            <article class="blog-card">
              <div class="blog-card__img-wrap">
                <a href={`/blog/${post.id}`}>
                  <img src={post.data.image} alt={post.data.title} loading="lazy" />
                </a>

                <span class="blog-card__date">{fmt(post.data.pubDate)}</span>
              </div>

              <div class="blog-card__body">
                <div class="blog-card__meta">
                  <span class="blog-card__meta-item">
                    <User size={15} strokeWidth={2.5} />
                    {post.data.author}
                  </span>

                  <span class="blog-card__meta-item">
                    <Tag size={15} strokeWidth={2.5} />
                    {post.data.category}
                  </span>
                </div>

                <h2 class="blog-card__title">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h2>

                <a href={`/blog/${post.id}`} class="blog-card__btn">
                  Read More
                  <span>→</span>
                </a>
              </div>
            </article>
          ))}
        </div>

        <aside class="blog-sidebar">
          <div class="blog-sidebar-inner">

          <div class="sidebar-widget">
            <h3 class="sidebar-widget__title">Brows Categories</h3>

            <ul class="sidebar-cat-list">
              {categories.map((cat) => (
                <li>
                  <a href="#">
                    <span class="cat-arrow">→</span>
                    {cat}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class="sidebar-widget">
            <h3 class="sidebar-widget__title">Recent Post</h3>

            <ul class="sidebar-recent-list">
              {posts.map((post) => (
                <li>
                  <a href={`/blog/${post.id}`} class="sidebar-recent__img-wrap">
                    <img src={post.data.image} alt={post.data.title} loading="lazy" />
                  </a>

                  <div class="sidebar-recent__info">
                    <a href={`/blog/${post.id}`} class="sidebar-recent__title">
                      {post.data.title}
                    </a>

                    <span class="sidebar-recent__date">
                      <CalendarDays size={13} strokeWidth={2} />
                      {fmt(post.data.pubDate)}
                    </span>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          </div><!-- /blog-sidebar-inner -->
        </aside>
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  .blog-section {
    padding: 80px 0;
    background: #ffffff;
  }

  .blog-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 32px;
    align-items: start;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(320px, 1fr));
    gap: 32px;
  }

  .blog-card {
    background: #fff8e8;
    border: 1px solid rgba(255, 196, 66, 0.15);
    border-radius: 16px;
    overflow: hidden;

    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease;
  }

  .blog-card:hover {
    transform: translateY(-8px);
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.08),
      0 8px 20px rgba(255, 196, 66, 0.12);
  }

  .blog-card__img-wrap {
    position: relative;
    overflow: hidden;
    padding: 8px;
  }

  .blog-card__img-wrap a {
    display: block;
    overflow: hidden;
    border-radius: 12px;
  }

  .blog-card__img-wrap img {
    width: 100%;
    height: 280px;

    display: block;

    object-fit: cover;
    object-position: center;

    border-radius: 12px;

    transition: transform 0.6s ease;
  }

  .blog-card:hover .blog-card__img-wrap img {
    transform: scale(1.08);
  }

  .blog-card__date {
    position: absolute;
    top: 24px;
    right: 24px;

    padding: 10px 16px;

    border-radius: 8px;

    background: var(--gcid-primary-color, #ffc342);
    color: var(--gcid-heading-color, #101932);

    font-family: "Cabin", sans-serif;
    font-size: 14px;
    font-weight: 700;
    line-height: 1;

    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  .blog-card__body {
    padding: 20px 22px 24px;

    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  .blog-card__meta-item {
    display: flex;
    align-items: center;
    gap: 6px;

    color: var(--gcid-body-color, #505658);

    font-family: "Cabin", sans-serif;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.2;
  }

  .blog-card__meta-item :global(svg) {
    color: var(--gcid-primary-color, #ffc342);
    flex-shrink: 0;
  }

  .blog-card__title {
    margin: 0;

    color: var(--gcid-heading-color, #101932);

    font-family: "Bitter", serif;
    font-size: 21px;
    font-weight: 600;
    line-height: 1.35;
  }

  .blog-card__title a {
    color: inherit;
    text-decoration: none;

    transition: color 0.3s ease;
  }

  .blog-card__title a:hover {
    color: var(--gcid-primary-color, #ffc342);
  }

  .blog-card__btn {
    width: max-content;

    margin-top: 6px;
    padding: 12px 24px;

    display: inline-flex;
    align-items: center;
    gap: 10px;

    border-radius: 999px;

    background: var(--gcid-primary-color, #ffc342);
    color: var(--gcid-heading-color, #101932);

    font-family: "Cabin", sans-serif;
    font-size: 14px;
    font-weight: 700;
    line-height: 1;

    text-decoration: none;

    transition:
      transform 0.3s ease,
      background-color 0.3s ease,
      color 0.3s ease;
  }

  .blog-card__btn:hover {
    transform: translateY(-2px);
    background: var(--gcid-heading-color, #101932);
    color: #ffffff;
  }

  .blog-card__btn span {
    font-size: 16px;
    line-height: 1;
  }

  /* Stretch the sidebar to match the blog-grid height so sticky has room to travel */
  .blog-sidebar {
    align-self: stretch;
  }

  /* Inner wrapper = what actually sticks */
  .blog-sidebar-inner {
    position: sticky;
    top: calc(var(--navbar-h, 80px) + 24px);

    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .sidebar-widget {
    background: #fff8e8;
    border: 1px solid rgba(255, 196, 66, 0.15);
    border-radius: 16px;
    overflow: hidden;

    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.04);
  }

  .sidebar-search-widget {
    padding: 18px;
  }

  .sidebar-search {
    display: flex;
    width: 100%;
  }

  .sidebar-search input {
    width: 100%;
    height: 52px;

    padding-inline: 16px;

    border: 1px solid rgba(0, 0, 0, 0.08);
    border-right: 0;
    border-radius: 10px 0 0 10px;

    color: var(--gcid-heading-color, #101932);
    font-family: "Cabin", sans-serif;
    font-size: 15px;

    outline: none;
  }

  .sidebar-search button {
    width: 58px;
    height: 52px;

    display: grid;
    place-items: center;

    border: 0;
    border-radius: 0 10px 10px 0;

    background: var(--gcid-primary-color, #ffc342);
    color: var(--gcid-heading-color, #101932);

    cursor: pointer;
  }

  .sidebar-widget__title {
    margin: 0;
    padding: 20px 24px;

    background: var(--gcid-primary-color, #ffc342);
    color: var(--gcid-heading-color, #101932);

    font-family: "Bitter", serif;
    font-size: 24px;
    font-weight: 600;
    line-height: 1.2;
  }

  .sidebar-cat-list {
    margin: 0;
    padding: 12px 20px 16px;

    list-style: none;
  }

  .sidebar-cat-list li {
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);

    transition: background-color 0.3s ease;
  }

  .sidebar-cat-list li:last-child {
    border-bottom: 0;
  }

  .sidebar-cat-list li a {
    padding: 18px 0;

    display: flex;
    align-items: center;
    gap: 10px;

    color: var(--gcid-heading-color, #101932);

    font-family: "Cabin", sans-serif;
    font-size: 16px;
    font-weight: 500;

    text-decoration: none;

    transition:
      color 0.3s ease,
      padding-left 0.3s ease;
  }

  .sidebar-cat-list li:hover a {
    padding-left: 8px;
    color: var(--gcid-primary-color, #ffc342);
  }

  .cat-arrow {
    color: var(--gcid-primary-color, #ffc342);
    font-size: 18px;
    font-weight: 700;
    line-height: 1;
  }

  .sidebar-recent-list {
    margin: 0;
    padding: 20px;

    display: flex;
    flex-direction: column;
    gap: 22px;

    list-style: none;
  }

  .sidebar-recent-list li {
    display: grid;
    grid-template-columns: 95px 1fr;
    gap: 15px;
    align-items: start;
  }

  .sidebar-recent__img-wrap {
    width: 95px;
    height: 75px;

    display: block;
    overflow: hidden;

    border-radius: 10px;
  }

  .sidebar-recent__img-wrap img {
    width: 100%;
    height: 100%;

    display: block;

    object-fit: cover;
    object-position: center;

    transition: transform 0.4s ease;
  }

  .sidebar-recent__img-wrap:hover img {
    transform: scale(1.08);
  }

  .sidebar-recent__info {
    min-width: 0;

    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sidebar-recent__title {
    color: var(--gcid-heading-color, #101932);

    display: -webkit-box;
    overflow: hidden;

    font-family: "Bitter", serif;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.35;

    text-decoration: none;

    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;

    transition: color 0.3s ease;
  }

  .sidebar-recent__title:hover {
    color: var(--gcid-primary-color, #ffc342);
  }

  .sidebar-recent__date {
    display: flex;
    align-items: center;
    gap: 6px;

    color: var(--gcid-primary-color, #ffc342);

    font-family: "Cabin", sans-serif;
    font-size: 13px;
    font-weight: 600;
    line-height: 1.2;
  }

  .sidebar-recent__date :global(svg) {
    flex-shrink: 0;
  }

  @media (max-width: 1200px) {
    .blog-layout {
      grid-template-columns: minmax(0, 1fr) 330px;
      gap: 28px;
    }

    .blog-grid {
      gap: 24px;
    }

    .blog-card__img-wrap img {
      height: 240px;
    }
  }

  @media (max-width: 980px) {
    .blog-section {
      padding: 60px 0;
    }

    .blog-layout {
      grid-template-columns: 1fr;
    }

    .blog-sidebar {
      position: static;
    }
  }

  @media (max-width: 767px) {
    .blog-section {
      padding: 40px 0;
    }

    .blog-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .blog-card__img-wrap img {
      height: 230px;
    }

    .blog-card__title {
      font-size: 19px;
    }

    .sidebar-widget__title {
      font-size: 22px;
    }
  }

  @media (max-width: 480px) {
    .blog-card__img-wrap img {
      height: 210px;
    }

    .blog-card__meta {
      gap: 12px;
    }

    .sidebar-recent-list li {
      grid-template-columns: 82px 1fr;
    }

    .sidebar-recent__img-wrap {
      width: 82px;
      height: 68px;
    }
  }
</style>